page {
    background: #f5f5f5;
    min-height: 100vh;
}

.container {
    padding: 0 24rpx 40rpx;
}

.custom-nav {
    display: flex;
    align-items: center;
    padding-bottom: 20rpx;
    background: #fff;
    margin: 0 -24rpx;
    padding-left: 24rpx;
    padding-right: 24rpx;
}

.nav-back {
    width: 60px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
}

.back-icon {
    font-size: 28px;
    color: #1a1a1a;
    font-weight: 300;
}

.nav-title {
    flex: 1;
    font-size: 36rpx;
    font-weight: 600;
    color: #1a1a1a;
    text-align: center;
    margin-right: 60px;
}

/* FAQ列表 */
.faq-list {
    margin-top: 24rpx;
}

.faq-item {
    background: #fff;
    border-radius: 16rpx;
    margin-bottom: 16rpx;
    overflow: hidden;
}

.faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 32rpx;
}

.question-text {
    flex: 1;
    font-size: 30rpx;
    font-weight: 500;
    color: #1a1a1a;
}

.arrow {
    font-size: 32rpx;
    color: #999;
    transition: transform 0.3s;
}

.arrow.down {
    transform: rotate(90deg);
}

.faq-answer {
    padding: 0 32rpx 32rpx;
    font-size: 28rpx;
    color: #666;
    line-height: 1.8;
    border-top: 1rpx solid #f0f0f0;
    padding-top: 24rpx;
    margin-top: -8rpx;
    background: #fafafa;
}

/* 联系客服 */
.contact-section {
    margin-top: 60rpx;
    text-align: center;
}

.contact-title {
    font-size: 28rpx;
    color: #999;
    margin-bottom: 24rpx;
}

.contact-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16rpx;
    width: 100%;
    height: 96rpx;
    background: linear-gradient(135deg, #16a34a, #15803d);
    color: #fff;
    font-size: 32rpx;
    font-weight: 600;
    border-radius: 48rpx;
    border: none;
}

.contact-btn::after {
    border: none;
}

.contact-icon {
    font-size: 36rpx;
}