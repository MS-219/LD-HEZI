page { background: #f5f5f7; min-height: 100vh; }
.container { padding: 0 0 40px 0; }
.custom-nav { display: flex; align-items: center; justify-content: space-between; padding: 0 20px; background: #fff; }
.nav-back { font-size: 24px; color: #333; width: 40px; }
.nav-title { font-size: 18px; font-weight: 600; color: #1a1a1a; }
.nav-placeholder { width: 40px; }

.tab-scroll { white-space: nowrap; background: #fff; border-bottom: 1px solid #f0f0f0; margin-bottom: 12px; }
.tab-bar { display: flex; padding: 0 16px; }
.tab-item { flex-shrink: 0; padding: 12px 16px; font-size: 14px; color: #6b7280; position: relative; font-weight: 500; }
.tab-active { color: #16a34a; font-weight: 600; }
.tab-active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 24px; height: 3px; background: #16a34a; border-radius: 2px; }

.order-list { padding: 0 16px; }
.order-card { background: #fff; border-radius: 16px; margin-bottom: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.03); }
.order-header { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; border-bottom: 1px solid #f9fafb; }
.order-no { font-size: 12px; color: #9ca3af; font-family: 'Courier New', monospace; }
.order-status { font-size: 13px; font-weight: 600; }
.status-0 { color: #f59e0b; }
.status-1 { color: #3b82f6; }
.status-2 { color: #8b5cf6; }
.status-3 { color: #16a34a; }
.status-4 { color: #ef4444; }

.order-body { display: flex; padding: 12px 16px; gap: 12px; align-items: center; }
.order-product-img { width: 80px; height: 80px; border-radius: 10px; flex-shrink: 0; background: #f3f4f6; }
.order-product-info { flex: 1; }
.order-product-name { font-size: 15px; font-weight: 600; color: #1a1a1a; display: block; margin-bottom: 4px; }
.order-qty { font-size: 13px; color: #9ca3af; display: block; margin-bottom: 6px; }
.order-cost { display: flex; align-items: center; gap: 4px; }
.cost-icon { font-size: 14px; }
.cost-value { font-size: 16px; font-weight: 700; color: #f59e0b; }

.order-footer { display: flex; justify-content: space-between; align-items: center; padding: 10px 16px; border-top: 1px solid #f9fafb; }
.order-time { font-size: 12px; color: #9ca3af; }
.order-arrow { font-size: 13px; color: #16a34a; font-weight: 500; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80px 0; gap: 12px; }
.empty-icon { font-size: 48px; }
.empty-text { font-size: 14px; color: #9ca3af; }
.loading-more { padding: 20px; text-align: center; }
.loading-text { font-size: 13px; color: #9ca3af; }
