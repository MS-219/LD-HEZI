/* Pages/creation/creation.wxss */
page {
    background: linear-gradient(180deg, #e6f9ed 0%, #f0fdf4 40%, #f9fafb 100%);
    min-height: 100vh;
}

.container {
    padding: 0 40rpx;
    padding-bottom: 260rpx;
    /* 黄金比例间距，避开 TabBar 且不留过多空白 */
    box-sizing: border-box;
}

.header-section {
    padding-bottom: 30rpx;
}

.page-title {
    font-size: 56rpx;
    font-weight: 800;
    color: #1a1a1a;
    display: block;
    margin-bottom: 24rpx;
}

.intro-bar {
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.intro-text {
    font-size: 28rpx;
    color: #4b5e5f;
    font-weight: 500;
}

/* 已消耗算力值卡片 */
.status-card {
    background: #ffffff;
    border-radius: 40rpx;
    padding: 40rpx;
    margin-bottom: 40rpx;
    box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.04);
    position: relative;
    overflow: hidden;
    min-height: 220rpx;
    /* 增加最小高度，防止内容加载前塌陷 */
    border: 1rpx solid rgba(22, 163, 74, 0.05);
    /* 增加极细的绿色边框更显精致 */
}

.status-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32rpx;
    position: relative;
    z-index: 2;
}

.status-label {
    font-size: 26rpx;
    color: #999ba0;
    margin-bottom: 10rpx;
    display: block;
}

.status-number {
    font-size: 60rpx;
    font-weight: 800;
    color: #f59e0b;
}

.status-unit {
    font-size: 26rpx;
    color: #f59e0b;
    margin-left: 6rpx;
}

.history-btn-box {
    background: linear-gradient(135deg, #3b3b75 0%, #25254a 100%);
    padding: 16rpx 32rpx;
    border-radius: 100rpx;
}

.history-txt {
    font-size: 24rpx;
    color: #fff;
    font-weight: 600;
}

.status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #f8faf9;
    padding: 24rpx 0;
    border-radius: 20rpx;
    position: relative;
    z-index: 2;
}

.status-item {
    flex: 1;
    text-align: center;
}

.item-label {
    font-size: 22rpx;
    color: #999ba0;
}

.item-val {
    font-size: 28rpx;
    font-weight: 700;
    color: #f59e0b;
}

.item-sep {
    width: 1rpx;
    height: 32rpx;
    background: rgba(0, 0, 0, 0.05);
}

/* 卡片装饰 */
.card-decoration {
    position: absolute;
    pointer-events: none;
    z-index: 1;
}

.deco-1 {
    width: 300rpx;
    height: 300rpx;
    background: radial-gradient(circle, rgba(22, 163, 74, 0.15) 0%, transparent 75%);
    top: -100rpx;
    right: -80rpx;
}

.deco-tool {
    font-size: 180rpx;
    opacity: 0.18;
    bottom: -50rpx;
    right: -30rpx;
    transform: rotate(-20deg);
    color: #e2e8f0;
    font-weight: bold;
}

/* 工具网格 */
.creation-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30rpx;
    margin-bottom: 40rpx;
    /* 增加网格本身的底部外边距 */
}

.create-card {
    background: #ffffff;
    border-radius: 40rpx;
    box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.02);
    overflow: hidden;
    position: relative;
}

.create-card.primary {
    grid-column: span 2;
}

.card-cover {
    width: 100%;
    height: 280rpx;
    background: #f5f5f5;
}

.card-info {
    padding: 24rpx 32rpx 32rpx;
    position: relative;
    z-index: 2;
}

.card-title {
    font-size: 32rpx;
    font-weight: 700;
    color: #1a1a1a;
}

.card-desc {
    font-size: 24rpx;
    color: #999ba0;
    margin-bottom: 20rpx;
    display: block;
}

.card-cost {
    display: flex;
    align-items: center;
    gap: 6rpx;
}

.cost-value {
    font-size: 30rpx;
    color: #666e75;
    font-weight: 600;
}

.start-btn {
    width: 200rpx;
    height: 60rpx;
    line-height: 60rpx;
    background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
    border-radius: 100rpx;
    color: #fff;
    font-size: 24rpx;
    font-weight: 700;
    margin: 0;
}

/* 小卡片专用 */
.create-card.small {
    padding: 32rpx;
    height: 300rpx;
    box-sizing: border-box;
}

.create-card.small .card-info {
    padding: 0;
    height: 100%;
    display: flex;
    flex-direction: column;
}

.create-card.small .card-desc {
    flex: 1;
}