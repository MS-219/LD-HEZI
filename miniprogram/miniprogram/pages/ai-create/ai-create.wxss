/* Pages/ai-create/ai-create.wxss */
page {
    background: linear-gradient(180deg, #DEF1DD 0%, #f0fdf4 50%, #f7f7f9 100%);
    background-attachment: fixed;
    min-height: 100vh;
}

.container {
    padding-bottom: 200rpx;
}

/* 导航栏 */
.custom-nav {
    display: flex;
    align-items: center;
    background: transparent;
    padding: 0 30rpx;
}

.nav-back {
    font-size: 40rpx;
    padding: 10rpx;
}

.nav-title {
    flex: 1;
    text-align: center;
    font-size: 34rpx;
    font-weight: 600;
    color: #1a1a1a;
    margin-right: 60rpx;
}

/* 内容布局 */
.content-wrapper {
    padding: 24rpx;
    padding-bottom: 280rpx;
    /* 增加底部间距，完全避开底部固定栏 */
}

/* 基础卡片样式 - 恢复纯白实色并增加装饰 */
.card {
    background: #ffffff;
    border-radius: 40rpx;
    padding: 32rpx;
    margin-bottom: 24rpx;
    box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.03);
    position: relative;
    overflow: hidden;
}

/* 装饰性图标 */
.card-deco {
    position: absolute;
    right: -25rpx;
    bottom: -35rpx;
    font-size: 160rpx;
    opacity: 0.12;
    transform: rotate(-20deg);
    pointer-events: none;
    z-index: 1;
    color: #e2e8f0;
}

.prompt-card {
    position: relative;
    z-index: 2;
}

/* 上传部分 */
.upload-section {
    padding: 32rpx;
}

.upload-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24rpx;
}

.upload-label {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
}

.upload-count {
    font-size: 24rpx;
    color: #999;
}

.image-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20rpx;
}

.image-item {
    position: relative;
    aspect-ratio: 1/1;
    border-radius: 16rpx;
    overflow: hidden;
    background: #f8fafc;
}

.grid-img {
    width: 100%;
    height: 100%;
}

.delete-btn {
    position: absolute;
    top: 8rpx;
    right: 8rpx;
    width: 36rpx;
    height: 36rpx;
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24rpx;
    z-index: 10;
}

.upload-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2rpx dashed #e2e8f0;
}

.plus {
    font-size: 60rpx;
    color: #cbd5e1;
}

.upload-hint {
    margin-top: 24rpx;
    font-size: 24rpx;
    color: #94a3b8;
    line-height: 1.5;
}

.optional-text {
    font-size: 20rpx;
    color: #cbd5e1;
    margin-left: 8rpx;
}

/* 输入框卡片 */
.prompt-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 16rpx;
}

.prompt-label {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
}

.prompt-example {
    font-size: 26rpx;
    color: #16a34a;
}

.prompt-input {
    width: 100%;
    height: 200rpx;
    font-size: 30rpx;
    color: #333;
    line-height: 1.6;
}

.prompt-footer {
    text-align: right;
    margin-top: 10rpx;
}

.char-count {
    font-size: 24rpx;
    color: #999;
}

/* 标题样式 */
.section-title {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 16rpx;
    padding-left: 10rpx;
    display: block;
}

/* 快捷词 */
.quick-prompts-wrapper {
    margin-bottom: 30rpx;
}

.quick-scroll {
    white-space: nowrap;
}

.quick-tag {
    display: inline-block;
    padding: 10rpx 24rpx;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 30rpx;
    font-size: 24rpx;
    color: #666;
    margin-right: 16rpx;
    border: 1px solid rgba(255, 255, 255, 1);
}

/* 选项区域 */
.option-section {
    margin-bottom: 30rpx;
}

.option-grid {
    display: flex;
    gap: 16rpx;
}

.option-item {
    flex: 1;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 16rpx;
    padding: 20rpx 0;
    text-align: center;
    border: 2rpx solid transparent;
    transition: all 0.2s;
}

.option-item.active {
    background: #16a34a;
    color: #fff;
    box-shadow: 0 4rpx 12rpx rgba(22, 163, 74, 0.2);
}

.opt-label {
    display: block;
    font-size: 28rpx;
}

.opt-cost {
    display: block;
    font-size: 20rpx;
    margin-top: 4rpx;
    opacity: 0.8;
}

.opt-desc {
    display: block;
    font-size: 20rpx;
    margin-top: 4rpx;
    opacity: 0.7;
}

/* 风格选块 */
.style-scroll {
    white-space: nowrap;
}

.style-item {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    padding: 16rpx 24rpx;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 16rpx;
    margin-right: 16rpx;
    border: 2rpx solid transparent;
}

.style-item.active {
    background: #16a34a;
    color: #fff;
}

.style-icon {
    font-size: 40rpx;
    margin-bottom: 6rpx;
}

.style-name {
    font-size: 22rpx;
}

/* 底部操作栏 */
.generate-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(20px);
    padding: 24rpx 32rpx env(safe-area-inset-bottom);
    box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
    z-index: 90;
}

.cost-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8rpx;
    margin-bottom: 20rpx;
}

.total-label {
    font-size: 24rpx;
    color: #666;
}

.total-value {
    font-size: 36rpx;
    font-weight: 700;
    color: #f59e0b;
}

.total-unit {
    font-size: 24rpx;
    color: #f59e0b;
}

.generate-btn {
    height: 90rpx;
    background: #16a34a;
    color: #fff;
    border-radius: 45rpx;
    font-size: 32rpx;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8rpx 20rpx rgba(22, 163, 74, 0.2);
}

.generate-btn.disabled {
    background: #cccccc;
    box-shadow: none;
}

.estimate-tip {
    text-align: center;
    font-size: 22rpx;
    color: #999;
    margin-top: 12rpx;
}

/* 结果展示 */
.result-title {
    font-size: 28rpx;
    font-weight: 600;
    margin-bottom: 20rpx;
    display: block;
}

.result-media {
    width: 100%;
    border-radius: 12rpx;
}

.result-btns {
    display: flex;
    gap: 20rpx;
    margin-top: 24rpx;
}

.ai-disclaimer {
    display: block;
    text-align: center;
    font-size: 20rpx;
    color: #94a3b8;
    margin-top: 16rpx;
    opacity: 0.8;
}

.res-btn {
    flex: 1;
    height: 80rpx;
    border-radius: 40rpx;
    font-size: 28rpx;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
}

.res-btn.save {
    background: #e2e8f0;
    color: #475569;
}

.res-btn.share {
    background: #dcfce7;
    color: #16a34a;
}

/* 加载遮罩 */
.loading-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 255, 255, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
}

.loading-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24rpx;
}

.loading-spinner {
    width: 60rpx;
    height: 60rpx;
    border: 4rpx solid #f3f3f3;
    border-top: 4rpx solid #16a34a;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% {
        transform: rotate(0deg);
    }

    100% {
        transform: rotate(360deg);
    }
}

.loading-text {
    font-size: 28rpx;
    color: #16a34a;
    font-weight: 600;
}

/* AI 文案结果区域 */
.copywriting-result {
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
    border-radius: 20rpx;
    padding: 32rpx;
    margin: 16rpx 0;
    border: 1rpx solid rgba(22, 163, 74, 0.1);
}

.copywriting-content {
    font-size: 30rpx;
    line-height: 1.8;
    color: #1a1a1a;
    white-space: pre-wrap;
    word-break: break-word;
}

.result-card .res-btn.save {
    background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
    color: #fff;
}