page {
    background: linear-gradient(180deg, #DEF1DD 0%, #f0fdf4 30%, #f5f5f5 100%);
    min-height: 100vh;
}

.container {
    padding: 0 24rpx 40rpx;
}

.custom-nav {
    display: flex;
    align-items: center;
    padding-bottom: 20rpx;
}

.nav-back {
    width: 60px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
}

.back-icon {
    font-size: 28px;
    color: #1a1a1a;
    font-weight: 300;
}

.nav-title {
    flex: 1;
    font-size: 36rpx;
    font-weight: 600;
    color: #1a1a1a;
    text-align: center;
    margin-right: 60px;
}

/* 邀请卡片 */
.invite-card {
    background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
    border-radius: 24rpx;
    padding: 48rpx 32rpx;
    margin-bottom: 24rpx;
    box-shadow: 0 10rpx 30rpx rgba(22, 163, 74, 0.25);
    color: #fff;
}

.card-header {
    text-align: center;
    margin-bottom: 40rpx;
}

.card-title {
    display: block;
    font-size: 36rpx;
    font-weight: 600;
    color: #fff;
    margin-bottom: 12rpx;
}

.card-subtitle {
    font-size: 26rpx;
    color: rgba(255, 255, 255, 0.8);
}

.invite-code-section {
    margin-bottom: 32rpx;
}

.code-label {
    display: block;
    font-size: 26rpx;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 16rpx;
}

.code-box {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 16rpx;
    padding: 24rpx;
}

.code-text {
    flex: 1;
    font-size: 40rpx;
    font-weight: 700;
    color: #fff;
    letter-spacing: 4rpx;
}

.copy-btn {
    background: #fff;
    color: #16a34a;
    font-size: 26rpx;
    padding: 16rpx 32rpx;
    border-radius: 32rpx;
    border: none;
    line-height: 1.5;
    font-weight: 600;
}

.copy-btn::after {
    border: none;
}

.share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
    width: 100%;
    height: 96rpx;
    background: #fff;
    color: #16a34a;
    font-size: 32rpx;
    font-weight: 600;
    border-radius: 48rpx;
    border: none;
}

.share-btn::after {
    border: none;
}

.share-icon {
    font-size: 36rpx;
}

/* 等级与进度卡片 */
.level-status-card {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(20px);
    border-radius: 24rpx;
    padding: 32rpx;
    margin-bottom: 24rpx;
    border: 1px solid rgba(255, 255, 255, 0.8);
    display: flex;
    flex-direction: column;
    gap: 24rpx;
}

.level-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.current-level {
    display: flex;
    flex-direction: column;
    gap: 4rpx;
}

.level-tag {
    font-size: 20rpx;
    color: #6b7280;
    text-transform: uppercase;
}

.level-name {
    font-size: 34rpx;
    font-weight: 700;
    color: #16a34a;
}

.level-rate {
    background: rgba(22, 163, 74, 0.1);
    padding: 12rpx 20rpx;
    border-radius: 12rpx;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
}

.rate-label {
    font-size: 18rpx;
    color: #16a34a;
}

.rate-value {
    font-size: 24rpx;
    font-weight: 600;
    color: #16a34a;
}

.progress-section {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
}

.progress-info {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
}

.device-total {
    font-size: 24rpx;
    color: #374151;
    font-weight: 500;
}

.next-tip {
    font-size: 22rpx;
    color: #6b7280;
}

.progress-bar-bg {
    height: 12rpx;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 6rpx;
    overflow: hidden;
}

.progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #16a34a, #22c55e);
    border-radius: 6rpx;
    transition: width 0.3s ease;
}

/* 统计卡片 */
.stats-card {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(20px);
    border-radius: 24rpx;
    padding: 32rpx;
    margin-bottom: 24rpx;
    border: 1px solid rgba(255, 255, 255, 0.8);
}

.stats-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 24rpx;
}

.stats-row {
    display: flex;
    align-items: center;
}

.stat-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.stat-num {
    font-size: 48rpx;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 8rpx;
}

.stat-num.reward {
    color: #16a34a;
}

.stat-label {
    font-size: 24rpx;
    color: #6b7280;
}

.stat-divider {
    width: 2rpx;
    height: 60rpx;
    background: #eee;
}

/* 规则卡片 */
.rules-card {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(20px);
    border-radius: 24rpx;
    padding: 32rpx;
    border: 1px solid rgba(255, 255, 255, 0.8);
}

.rules-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 24rpx;
}

.rule-item {
    display: flex;
    align-items: center;
    margin-bottom: 20rpx;
}

.rule-item:last-child {
    margin-bottom: 0;
}

.rule-num {
    width: 40rpx;
    height: 40rpx;
    background: linear-gradient(135deg, #16a34a, #15803d);
    color: #fff;
    font-size: 24rpx;
    font-weight: 600;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 20rpx;
}

.rule-text {
    flex: 1;
    font-size: 28rpx;
    color: #333;
}

/* 邀请用户列表 */
.users-card {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(20px);
    border-radius: 24rpx;
    padding: 32rpx;
    margin-bottom: 24rpx;
    border: 1px solid rgba(255, 255, 255, 0.8);
}

.users-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 24rpx;
}

.user-list {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
}

.user-item {
    display: flex;
    align-items: center;
    background: #fff;
    padding: 24rpx;
    border-radius: 16rpx;
}

.user-avatar {
    width: 80rpx;
    height: 80rpx;
    border-radius: 50%;
    overflow: hidden;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 20rpx;
}

.user-avatar image {
    width: 100%;
    height: 100%;
}

.avatar-placeholder {
    font-size: 40rpx;
}

.user-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8rpx;
}

.user-name {
    font-size: 28rpx;
    font-weight: 500;
    color: #1a1a1a;
}

.user-time {
    font-size: 24rpx;
    color: #999;
}

.user-reward {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4rpx;
}

.reward-amount {
    font-size: 28rpx;
    font-weight: 600;
    color: #16a34a;
}

.reward-amount.highlight {
    color: #f59e0b;
}

.reward-amount.zero {
    color: #9ca3af;
    font-weight: normal;
}

.reward-amount.zero {
    color: #9ca3af;
    font-weight: normal;
}

.reward-label {
    font-size: 22rpx;
    color: #999;
}

/* 暂无邀请 */
.empty-users {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(20px);
    border-radius: 24rpx;
    padding: 60rpx 32rpx;
    margin-bottom: 24rpx;
    border: 1px solid rgba(255, 255, 255, 0.8);
    display: flex;
    flex-direction: column;
    align-items: center;
}

.empty-icon {
    font-size: 80rpx;
    margin-bottom: 20rpx;
    opacity: 0.5;
}

.empty-text {
    font-size: 30rpx;
    font-weight: 500;
    color: #666;
    margin-bottom: 12rpx;
}

.empty-tip {
    font-size: 26rpx;
    color: #999;
    text-align: center;
}

/* 我的邀请人卡片 */
.inviter-card {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(20px);
    border-radius: 24rpx;
    padding: 32rpx;
    margin-bottom: 24rpx;
    border: 1px solid rgba(255, 255, 255, 0.8);
}

.inviter-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 24rpx;
}

.inviter-bound {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.6);
    padding: 20rpx 24rpx;
    border-radius: 16rpx;
}

.inviter-avatar {
    width: 80rpx;
    height: 80rpx;
    border-radius: 50%;
    margin-right: 20rpx;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.inviter-avatar image {
    width: 100%;
    height: 100%;
}

.inviter-name {
    flex: 1;
    font-size: 28rpx;
    color: #333;
    font-weight: 500;
}

.bound-tag {
    font-size: 22rpx;
    color: #07c160;
    background: rgba(7, 193, 96, 0.1);
    padding: 4rpx 12rpx;
    border-radius: 8rpx;
}

.inviter-unbound {
    padding: 10rpx 0;
}

.bind-prompt {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20rpx 0;
}

.prompt-text {
    font-size: 26rpx;
    color: #999;
}

.prompt-link {
    font-size: 28rpx;
    color: #07c160;
    font-weight: 500;
    margin-left: 10rpx;
    text-decoration: underline;
}

.bind-input-row {
    display: flex;
    align-items: center;
}

.code-input {
    flex: 1;
    height: 80rpx;
    background: #fff;
    border-radius: 12rpx;
    padding: 0 24rpx;
    font-size: 28rpx;
    margin-right: 16rpx;
    border: 1px solid #ddd;
}

.bind-btn {
    width: 120rpx !important;
    height: 80rpx;
    line-height: 80rpx;
    background: linear-gradient(135rpx, #07c160, #06ae56);
    color: #fff;
    font-size: 26rpx;
    padding: 0;
    margin: 0;
    border-radius: 12rpx;
}

.cancel-btn {
    width: 100rpx !important;
    height: 80rpx;
    line-height: 80rpx;
    background: #f5f5f5;
    color: #666;
    font-size: 26rpx;
    padding: 0;
    margin: 0 0 0 12rpx;
    border-radius: 12rpx;
}