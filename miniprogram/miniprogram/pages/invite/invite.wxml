<view class="container">
    <!-- 自定义导航栏 -->
    <view class="custom-nav" style="padding-top: {{navBarTop}}px;">
        <view class="nav-back" bindtap="goBack">
            <text class="back-icon">‹</text>
        </view>
        <text class="nav-title">邀请好友</text>
    </view>
    <!-- 邀请卡片 -->
    <view class="invite-card">
        <view class="card-header">
            <text class="card-title">🎁 邀请好友 共享收益</text>
            <text class="card-subtitle">每成功邀请一位好友，获得丰厚奖励</text>
        </view>
        <!-- 邀请码 -->
        <view class="invite-code-section">
            <text class="code-label">我的邀请码</text>
            <view class="code-box">
                <text class="code-text">{{inviteCode}}</text>
                <button class="copy-btn" bindtap="copyInviteCode">复制</button>
            </view>
        </view>
        <!-- 分享按钮 -->
        <button class="share-btn" open-type="share">
            <text class="share-icon">📤</text>
            <text>立即分享给好友</text>
        </button>
    </view>
    <!-- 等级与进度 -->
    <view class="level-status-card">
        <view class="level-header">
            <view class="current-level">
                <text class="level-tag">当前等级</text>
                <text class="level-name">{{currentLevelName}}</text>
            </view>
        </view>
        <view class="progress-section">
            <view class="progress-info">
                <text class="next-tip">{{nextLevelDesc}}</text>
            </view>
            <view class="progress-bar-bg" wx:if="{{nextLevelConfig}}">
                <view class="progress-bar-fill" style="width: {{ (totalDeviceCount / nextLevelConfig.threshold) * 100 > 100 ? 100 : (totalDeviceCount / nextLevelConfig.threshold) * 100 }}%"></view>
            </view>
        </view>
    </view>
    <!-- 我的邀请人 -->
    <view class="inviter-card">
        <view class="inviter-title">我的邀请人</view>
        <!-- 已绑定邀请人 -->
        <view class="inviter-bound" wx:if="{{hasInviter}}">
            <view class="inviter-avatar">
                <image src="{{inviterAvatar}}" mode="aspectFill" wx:if="{{inviterAvatar}}"></image>
                <text class="avatar-placeholder" wx:else>👤</text>
            </view>
            <text class="inviter-name">{{inviterNickname}}</text>
            <text class="bound-tag">已绑定</text>
        </view>
        <!-- 未绑定邀请人 -->
        <view class="inviter-unbound" wx:else>
            <view class="bind-input-row" wx:if="{{showBindInput}}">
                <input class="code-input" placeholder="请输入邀请码" value="{{inputCode}}" bindinput="onInputCode" maxlength="20" />
                <button class="bind-btn" bindtap="submitBindCode">绑定</button>
                <button class="cancel-btn" bindtap="cancelBind">取消</button>
            </view>
            <view class="bind-prompt" wx:else bindtap="showBindInput">
                <text class="prompt-text">还没有邀请人？</text>
                <text class="prompt-link">点击填写邀请码</text>
            </view>
        </view>
    </view>
    <!-- 邀请统计 -->
    <view class="stats-card">
        <view class="stats-title">我的邀请成果</view>
        <view class="stats-row">
            <view class="stat-item">
                <text class="stat-num">{{inviteCount}}</text>
                <text class="stat-label">邀请人数</text>
            </view>
            <view class="stat-divider"></view>
            <view class="stat-item">
                <text class="stat-num reward">¥{{totalReward}}</text>
                <text class="stat-label">累计奖励</text>
            </view>
            <view class="stat-divider"></view>
            <view class="stat-item">
                <text class="stat-num online">{{onlineDeviceCount}}</text>
                <text class="stat-label">在线设备</text>
            </view>
        </view>
    </view>
    <!-- 邀请用户列表 -->
    <view class="users-card" wx:if="{{invitedUsers.length > 0}}">
        <view class="users-title">已邀请用户</view>
        <view class="user-list">
            <view class="user-item" wx:for="{{invitedUsers}}" wx:key="id">
                <view class="user-avatar">
                    <image src="{{item.avatarUrl}}" mode="aspectFill" wx:if="{{item.avatarUrl}}"></image>
                    <text class="avatar-placeholder" wx:else>👤</text>
                </view>
                <view class="user-info">
                    <text class="user-name">{{item.nickname}}</text>
                    <text class="user-time">{{item.registerTime}} 注册</text>
                </view>
                <view class="user-reward">
                    <text class="reward-amount {{item.deviceCount > 0 ? '' : 'zero'}}">
                        {{item.deviceCount || 0}}台
                    </text>
                    <text class="reward-label">设备</text>
                    <view class="reward-divider" style="height: 12rpx;"></view>
                    <text class="reward-amount highlight">+{{item.reward || '0.00'}}元</text>
                    <text class="reward-label">贡献收益</text>
                </view>
            </view>
        </view>
    </view>
    <!-- 暂无邀请 -->
    <view class="empty-users" wx:if="{{invitedUsers.length === 0 && !loading}}">
        <text class="empty-icon">👥</text>
        <text class="empty-text">暂无邀请用户</text>
        <text class="empty-tip">分享邀请码给好友，邀请成功后将显示在这里</text>
    </view>
    <!-- 邀请规则 -->
    <view class="rules-card">
        <view class="rules-title">邀请规则</view>
        <view class="rule-item">
            <text class="rule-num">1</text>
            <text class="rule-text">分享专属邀请链接给好友</text>
        </view>
        <view class="rule-item">
            <text class="rule-num">2</text>
            <text class="rule-text">好友通过链接注册并绑定设备</text>
        </view>
        <view class="rule-item">
            <text class="rule-num">3</text>
            <text class="rule-text">好友产生收益，您获得相应奖励</text>
        </view>
    </view>
</view>