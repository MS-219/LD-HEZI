page {
    min-height: 100vh;
    background: linear-gradient(180deg, #eef7f2 0%, #f6f8fb 44%, #f7f8fb 100%);
    color: #172033;
    padding-bottom: 40px;
}

.container {
    padding: 18px;
    padding-top: 104px;
    padding-bottom: 52px;
}

.nav-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 44px;
    padding-top: 48px;
    background: rgba(246, 248, 251, 0.86);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-left: 16px;
    padding-right: 16px;
    z-index: 999;
}

.nav-back {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.84);
    box-shadow: 0 8px 18px rgba(31, 77, 53, 0.08);
}

.back-icon {
    font-size: 28px;
    color: #334155;
    font-weight: 300;
    line-height: 1;
    margin-top: -2px;
}

.nav-title {
    font-size: 17px;
    font-weight: 800;
    color: #172033;
    letter-spacing: 0;
}

.nav-placeholder {
    width: 36px;
}

.device-header-card,
.chart-card,
.action-card {
    position: relative;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 22px;
    box-shadow: 0 16px 38px rgba(35, 91, 58, 0.08);
    overflow: hidden;
}

.device-header-card {
    padding: 20px;
    margin-bottom: 18px;
}

.header-glow {
    position: absolute;
    top: -80px;
    right: -76px;
    width: 180px;
    height: 180px;
    background: radial-gradient(circle, rgba(47, 125, 243, 0.18) 0%, rgba(24, 180, 97, 0.08) 44%, rgba(255, 255, 255, 0) 70%);
    pointer-events: none;
}

.header-top {
    position: relative;
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
}

.icon-box {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, #effaf3 0%, #e7f0ff 100%);
    border: 1px solid rgba(226, 239, 231, 0.9);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 12px 24px rgba(35, 91, 58, 0.08);
    flex-shrink: 0;
}

.device-icon-img {
    width: 48px;
    height: 48px;
}

.device-meta {
    flex: 1;
    min-width: 0;
}

.meta-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
}

.device-title-wrap {
    min-width: 0;
}

.device-name {
    display: block;
    font-size: 20px;
    font-weight: 800;
    color: #172033;
    line-height: 1.25;
    max-width: 190px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.device-sn-row {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 7px;
    min-width: 0;
}

.sn-label {
    font-size: 10px;
    color: #2f7df3;
    background: rgba(47, 125, 243, 0.08);
    border-radius: 5px;
    padding: 2px 5px;
    font-weight: 800;
    flex-shrink: 0;
}

.device-sn {
    font-size: 12px;
    color: #8a96a6;
    font-weight: 700;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.status-tag {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 11px;
    border-radius: 16px;
    font-size: 12px;
    font-weight: 800;
    flex-shrink: 0;
}

.status-tag.online {
    background: #ecfdf5;
    color: #059669;
}

.status-tag.offline {
    background: #f1f5f9;
    color: #64748b;
}

.dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: currentColor;
}

.stats-panel {
    position: relative;
    display: flex;
    align-items: stretch;
    padding: 15px 14px;
    background: rgba(248, 252, 249, 0.78);
    border: 1px solid rgba(226, 239, 231, 0.76);
    border-radius: 18px;
}

.stat-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
    min-width: 0;
}

.stat-item.right {
    align-items: flex-end;
    text-align: right;
}

.label {
    font-size: 12px;
    color: #8a96a6;
    font-weight: 600;
}

.value {
    font-size: 22px;
    font-weight: 800;
    color: #172033;
    line-height: 1.15;
}

.value.highlight {
    color: #2f7df3;
}

.value.time {
    font-size: 14px;
    font-weight: 800;
    max-width: 150px;
    overflow-wrap: break-word;
}

.stat-divider {
    width: 1px;
    margin: 0 14px;
    background: rgba(45, 74, 58, 0.12);
}

.chart-card {
    padding: 20px;
    margin-bottom: 18px;
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 14px;
}

.card-title {
    display: block;
    font-size: 17px;
    font-weight: 800;
    color: #172033;
    margin-bottom: 4px;
}

.card-desc {
    display: block;
    font-size: 12px;
    color: #8a96a6;
}

.card-subtitle {
    font-size: 11px;
    color: #2f7df3;
    background: rgba(47, 125, 243, 0.08);
    padding: 5px 8px;
    border-radius: 10px;
    font-weight: 700;
}

.chart-wrapper {
    width: 100%;
    height: 230px;
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(248, 252, 249, 0.88), rgba(255, 255, 255, 0.3));
    overflow: hidden;
}

.chart-canvas {
    width: 100%;
    height: 100%;
}

.action-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 16px;
    background: rgba(255, 255, 255, 0.82);
}

.action-copy {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
}

.action-title {
    font-size: 15px;
    color: #172033;
    font-weight: 800;
}

.action-subtitle {
    font-size: 12px;
    color: #8a96a6;
}

.unbind-btn {
    margin: 0;
    min-width: 112px;
    height: 42px;
    line-height: 42px;
    padding: 0 18px;
    background: #fff7f7;
    color: #ef4444;
    border: 1px solid #fecaca;
    font-size: 15px;
    font-weight: 800;
    border-radius: 15px;
    box-shadow: 0 8px 18px rgba(239, 68, 68, 0.08);
}

.unbind-btn::after {
    border: none;
}

.btn-hover {
    background: #fef2f2;
    transform: scale(0.98);
}
