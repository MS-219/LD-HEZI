<view class="container">
    <!-- 自定义导航栏 -->
    <view class="nav-bar">
        <view class="nav-back" bindtap="goBack">
            <text class="back-icon">‹</text>
        </view>
        <text class="nav-title">设备详情</text>
        <view class="nav-placeholder"></view>
    </view>
    <view class="device-header-card">
        <view class="header-glow"></view>
        <view class="header-top">
            <view class="icon-box">
                <image class="device-icon-img" src="/images/product.png" mode="aspectFit"></image>
            </view>
            <view class="device-meta">
                <view class="meta-row">
                    <view class="device-title-wrap">
                        <text class="device-name">{{device.name || '聚芯算力节点'}}</text>
                        <view class="device-sn-row">
                            <text class="sn-label">SN</text>
                            <text class="device-sn">{{device.bindCode || device.sn}}</text>
                        </view>
                    </view>
                    <view class="status-tag {{device.status === 1 ? 'online' : 'offline'}}">
                        <text class="dot"></text>
                        <text>{{device.status === 1 ? '运行中' : '离线'}}</text>
                    </view>
                </view>
            </view>
        </view>
        <view class="stats-panel">
            <view class="stat-item primary">
                <text class="label">可回收聚芯算力值</text>
                <text class="value highlight">{{device.hashrate || 0}}</text>
            </view>
            <view class="stat-divider"></view>
            <view class="stat-item right">
                <text class="label">绑定时间</text>
                <text class="value time">{{device.bindTime || '-'}}</text>
            </view>
        </view>
    </view>

    <view class="chart-card">
        <view class="card-header">
            <view>
                <text class="card-title">收益趋势</text>
                <text class="card-desc">近 7 日收益统计</text>
            </view>
            <text class="card-subtitle">单位：元</text>
        </view>
        <view class="chart-wrapper">
            <canvas type="2d" id="earningsChart" class="chart-canvas"></canvas>
        </view>
    </view>

    <view class="action-card">
        <view class="action-copy">
            <text class="action-title">设备操作</text>
            <text class="action-subtitle">解除后将从当前账号移除</text>
        </view>
        <button class="unbind-btn" hover-class="btn-hover" bindtap="unbindDevice">解除绑定</button>
    </view>
</view>
