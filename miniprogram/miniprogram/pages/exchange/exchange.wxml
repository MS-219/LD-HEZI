<view class="container">
    <view class="custom-nav" style="padding-top: {{navBarTop}}px; height: {{navBarHeight}}px; line-height: {{navBarHeight}}px;">
        <view class="nav-back" bindtap="onGoBack">‹</view>
        <text class="nav-title">兑换设备</text>
        <view class="nav-right" bindtap="goToOrders">订单</view>
    </view>

    <!-- 算力值信息栏 -->
    <view class="hashrate-info">
        <view class="hashrate-left">
            <text class="hashrate-icon">⚡</text>
            <text class="hashrate-label">可用算力值</text>
        </view>
        <text class="hashrate-amount">{{availableHashrate}}</text>
    </view>

    <!-- 等级提示 -->
    <view class="level-tip" wx:if="{{userLevel < 1}}">
        <text class="tip-icon">💡</text>
        <text class="tip-text">您当前为普通用户，需升级后才能兑换设备</text>
    </view>

    <view class="level-badge-bar" wx:if="{{userLevel >= 1}}">
        <text class="current-level">当前等级：{{levelNames[userLevel]}}</text>
    </view>

    <!-- 商品列表 -->
    <view class="product-list" wx:if="{{!loading}}">
        <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
            <image class="product-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
            <view class="product-info">
                <text class="product-name">{{item.name}}</text>
                <text class="product-desc" wx:if="{{item.description}}">{{item.description}}</text>
                <view class="product-price-row">
                    <view class="price-main">
                        <text class="price-icon">⚡</text>
                        <text class="price-value">{{item.userHashratePrice}}</text>
                        <text class="price-unit">算力值</text>
                    </view>
                    <text class="price-yuan">≈ ¥{{item.userPrice}}</text>
                </view>
                <view class="product-stock" wx:if="{{item.stock !== null && item.stock !== undefined}}">
                    <text class="stock-text">库存: {{item.stock}}</text>
                </view>
            </view>
        </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && products.length === 0}}">
        <text class="empty-icon">📦</text>
        <text class="empty-text">暂无可兑换设备</text>
    </view>

    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{loading}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
    </view>
</view>
