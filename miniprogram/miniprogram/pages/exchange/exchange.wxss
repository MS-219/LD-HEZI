page { background: linear-gradient(180deg, #DEF1DD 0%, #f0fdf4 50%, #f7f7f9 100%); min-height: 100vh; }
.container { padding: 0 20px 40px 20px; }
.custom-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
.nav-back { font-size: 24px; color: #333; width: 40px; }
.nav-title { font-size: 18px; font-weight: 600; color: #1a1a1a; }
.nav-right { font-size: 14px; color: #16a34a; font-weight: 500; width: 40px; text-align: right; }

.hashrate-info { display: flex; justify-content: space-between; align-items: center; background: linear-gradient(135deg, #fffbeb, #fef3c7); border-radius: 16px; padding: 16px 20px; margin-bottom: 16px; }
.hashrate-left { display: flex; align-items: center; gap: 8px; }
.hashrate-icon { font-size: 20px; }
.hashrate-label { font-size: 14px; color: #92400e; font-weight: 500; }
.hashrate-amount { font-size: 24px; font-weight: 800; color: #f59e0b; }

.level-tip { display: flex; align-items: center; gap: 8px; background: rgba(251,191,36,0.1); border: 1px solid rgba(251,191,36,0.3); border-radius: 12px; padding: 12px 16px; margin-bottom: 16px; }
.tip-icon { font-size: 16px; }
.tip-text { font-size: 13px; color: #b45309; }

.level-badge-bar { display: flex; align-items: center; margin-bottom: 16px; padding: 0 4px; }
.current-level { font-size: 13px; color: #16a34a; font-weight: 600; background: rgba(22,163,74,0.1); padding: 4px 12px; border-radius: 20px; }

.product-list { display: flex; flex-direction: column; gap: 16px; }
.product-card { background: rgba(255,255,255,0.7); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.8); border-radius: 20px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.04); }
.product-image { width: 100%; height: 400rpx; display: block; }
.product-info { padding: 16px 20px; }
.product-name { font-size: 17px; font-weight: 600; color: #1a1a1a; display: block; margin-bottom: 6px; }
.product-desc { font-size: 13px; color: #6b7280; display: block; margin-bottom: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.product-price-row { display: flex; align-items: baseline; justify-content: space-between; }
.price-main { display: flex; align-items: baseline; gap: 4px; }
.price-icon { font-size: 16px; }
.price-value { font-size: 22px; font-weight: 800; color: #f59e0b; }
.price-unit { font-size: 12px; color: #92400e; margin-left: 2px; }
.price-yuan { font-size: 13px; color: #9ca3af; }
.product-stock { margin-top: 8px; }
.stock-text { font-size: 12px; color: #9ca3af; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80px 0; gap: 12px; }
.empty-icon { font-size: 48px; }
.empty-text { font-size: 14px; color: #9ca3af; }

.loading-state { display: flex; flex-direction: column; align-items: center; padding: 80px 0; gap: 12px; }
.loading-spinner { width: 32px; height: 32px; border: 3px solid #e5e7eb; border-top-color: #16a34a; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 14px; color: #9ca3af; }
