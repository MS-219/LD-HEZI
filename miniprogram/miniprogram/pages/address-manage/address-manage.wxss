page { background: #f5f5f7; min-height: 100vh; }
.container { padding: 0 16px 40px 16px; }
.custom-nav { display: flex; align-items: center; justify-content: space-between; padding: 0 4px; margin-bottom: 16px; }
.nav-back { font-size: 24px; color: #333; width: 40px; }
.nav-title { font-size: 18px; font-weight: 600; color: #1a1a1a; }
.nav-placeholder { width: 40px; }

.addr-card { background: #fff; border-radius: 16px; margin-bottom: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.03); }
.addr-main { padding: 16px 20px; }
.addr-top { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
.addr-name { font-size: 16px; font-weight: 600; color: #1a1a1a; }
.addr-phone { font-size: 14px; color: #6b7280; }
.addr-default { font-size: 11px; color: #16a34a; background: rgba(22,163,74,0.1); padding: 2px 8px; border-radius: 20px; font-weight: 600; }
.addr-detail { font-size: 13px; color: #9ca3af; line-height: 1.4; }
.addr-actions { display: flex; justify-content: flex-end; gap: 20px; padding: 10px 20px; border-top: 1px solid #f9fafb; }
.action-btn { font-size: 13px; font-weight: 500; }
.set-default { color: #3b82f6; }
.delete { color: #ef4444; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 100px 0 60px; gap: 16px; }
.empty-icon { font-size: 80px; text-shadow: 0 10px 20px rgba(0,0,0,0.05); }
.empty-text { font-size: 15px; color: #9ca3af; letter-spacing: 1px; }

.add-btn { 
    width: 85% !important; 
    margin: 40px auto 20px !important; 
    display: block !important;
    background: linear-gradient(135deg, #22c55e, #16a34a) !important; 
    color: #fff !important; 
    border: none !important; 
    border-radius: 100rpx !important; 
    height: 96rpx !important; 
    line-height: 96rpx !important; 
    font-size: 32rpx !important; 
    font-weight: 600 !important; 
    box-shadow: 0 8rpx 24rpx rgba(34, 197, 94, 0.3) !important;
    transition: all 0.2s;
}
.add-btn:active { transform: scale(0.98); opacity: 0.9; }

/* 表单 */
.form-card { background: #fff; border-radius: 16px; padding: 0; overflow: hidden; }
.form-item { display: flex; align-items: center; padding: 16px 20px; border-bottom: 1px solid #f5f5f5; }
.form-item:last-child { border-bottom: none; }
.switch-item { justify-content: space-between; }
.form-label { font-size: 15px; color: #374151; font-weight: 500; min-width: 70px; flex-shrink: 0; }
.form-input { flex: 1; font-size: 15px; color: #1a1a1a; }
.picker-input { color: #9ca3af; }

.form-actions { display: flex; gap: 16px; margin-top: 30px; padding: 0 10px; }
.save-btn { flex: 1; background: linear-gradient(135deg, #22c55e, #16a34a) !important; color: #fff !important; border: none !important; border-radius: 100rpx !important; height: 96rpx !important; line-height: 96rpx !important; font-size: 32rpx !important; font-weight: 600 !important; box-shadow: 0 8rpx 20rpx rgba(34, 197, 94, 0.25) !important; }
.cancel-btn { flex: 1; background: #f3f4f6 !important; color: #6b7280 !important; border: none !important; border-radius: 100rpx !important; height: 96rpx !important; line-height: 96rpx !important; font-size: 32rpx !important; font-weight: 600 !important; }
