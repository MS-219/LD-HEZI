<scroll-view class="scrollarea" scroll-y type="list">
    <view class="container">
        <!-- 自定义导航栏 -->
        <view class="custom-nav" style="padding-top: {{navBarTop}}px; height: {{navBarHeight}}px;">
            <view class="nav-back" bindtap="goBack">
                <text class="back-icon">‹</text>
            </view>
            <text class="nav-title">设备详情</text>
        </view>
        <!-- 加载中 -->
        <view class="loading-state" wx:if="{{loading}}">
            <view class="loading-spinner"></view>
            <text>加载中...</text>
        </view>
        <!-- 内容区 -->
        <block wx:if="{{!loading}}">
            <!-- 设备信息卡片 -->
            <view class="device-card">
                <view class="device-header">
                    <view class="device-icon">
                        <image src="/images/product.png" mode="aspectFit"></image>
                    </view>
                    <view class="device-info">
                        <text class="device-name">{{device.name}}</text>
                        <text class="device-code">绑定码: {{device.bindCode}}</text>
                    </view>
                    <view class="device-status {{device.status === 1 ? 'online' : 'offline'}}">
                        <view class="status-indicator"></view>
                        <text>{{device.statusText}}</text>
                    </view>
                </view>
                <!-- 设备所属用户 -->
                <view class="device-owner">
                    <view class="owner-avatar">
                        <image wx:if="{{device.ownerAvatar}}" src="{{device.ownerAvatar}}" mode="aspectFill"></image>
                        <text wx:else class="avatar-placeholder">👤</text>
                    </view>
                    <view class="owner-detail">
                        <text class="owner-name">{{device.ownerNickname}}</text>
                        <text class="owner-label">设备所有者</text>
                    </view>
                </view>
                <!-- 设备统计 -->
                <view class="device-stats">
                    <view class="stat-item">
                        <text class="stat-label">绑定时间</text>
                        <text class="stat-value">{{device.bindTime}}</text>
                    </view>
                    <view class="stat-divider"></view>
                    <view class="stat-item">
                        <text class="stat-label">最后心跳</text>
                        <text class="stat-value time">{{device.lastHeartbeat || '暂无'}}</text>
                    </view>
                </view>
            </view>
        </block>
    </view>
</scroll-view>