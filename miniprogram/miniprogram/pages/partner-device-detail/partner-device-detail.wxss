page {
    background: linear-gradient(180deg, #DEF1DD 0%, #f0fdf4 30%, #f5f5f5 100%);
    min-height: 100vh;
}

.container {
    padding: 0 24rpx 40rpx;
}

/* 导航栏 */
.custom-nav {
    display: flex;
    align-items: center;
    padding-bottom: 20rpx;
}

.nav-back {
    width: 60px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
}

.back-icon {
    font-size: 28px;
    color: #1a1a1a;
    font-weight: 300;
}

.nav-title {
    flex: 1;
    font-size: 36rpx;
    font-weight: 600;
    color: #1a1a1a;
    text-align: center;
    margin-right: 60px;
}

/* 设备卡片 */
.device-card {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(20px);
    border-radius: 24rpx;
    padding: 28rpx;
    margin-bottom: 24rpx;
    border: 1px solid rgba(255, 255, 255, 0.9);
}

.device-header {
    display: flex;
    align-items: center;
    padding-bottom: 24rpx;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    margin-bottom: 20rpx;
}

.device-icon {
    width: 80rpx;
    height: 80rpx;
    background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
    border-radius: 20rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 20rpx;
    overflow: hidden;
}

.device-icon image {
    width: 100%;
    height: 100%;
}

.device-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6rpx;
}

.device-name {
    font-size: 32rpx;
    font-weight: 600;
    color: #1a1a1a;
}

.device-code {
    font-size: 24rpx;
    color: #9ca3af;
}

.device-status {
    display: flex;
    align-items: center;
    gap: 8rpx;
    padding: 10rpx 20rpx;
    border-radius: 24rpx;
    font-size: 26rpx;
    font-weight: 500;
}

.device-status.online {
    background: rgba(22, 163, 74, 0.12);
    color: #16a34a;
}

.device-status.offline {
    background: rgba(245, 158, 11, 0.12);
    color: #f59e0b;
}

.status-indicator {
    width: 12rpx;
    height: 12rpx;
    border-radius: 50%;
}

.device-status.online .status-indicator {
    background: #16a34a;
    box-shadow: 0 0 10rpx rgba(22, 163, 74, 0.5);
}

.device-status.offline .status-indicator {
    background: #f59e0b;
}

/* 设备所有者 */
.device-owner {
    display: flex;
    align-items: center;
    gap: 16rpx;
    padding: 20rpx;
    background: linear-gradient(135deg, rgba(22, 163, 74, 0.08), rgba(22, 163, 74, 0.04));
    border-radius: 16rpx;
    margin-bottom: 24rpx;
}

.owner-avatar {
    width: 64rpx;
    height: 64rpx;
    border-radius: 50%;
    overflow: hidden;
    background: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
}

.owner-avatar image {
    width: 100%;
    height: 100%;
}

.avatar-placeholder {
    font-size: 32rpx;
}

.owner-detail {
    display: flex;
    flex-direction: column;
    gap: 4rpx;
}

.owner-name {
    font-size: 28rpx;
    font-weight: 600;
    color: #374151;
}

.owner-label {
    font-size: 22rpx;
    color: #9ca3af;
}

/* 设备统计 */
.device-stats {
    display: flex;
    align-items: center;
    justify-content: space-around;
}

.stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8rpx;
    flex: 1;
}

.stat-label {
    font-size: 22rpx;
    color: #9ca3af;
}

.stat-value {
    font-size: 26rpx;
    font-weight: 600;
    color: #374151;
}

.stat-value.highlight {
    font-size: 30rpx;
    color: #16a34a;
}

.stat-value.time {
    font-size: 22rpx;
    font-weight: normal;
    color: #6b7280;
}

.stat-divider {
    width: 1rpx;
    height: 50rpx;
    background: #e5e7eb;
}

/* 图表卡片 */
.chart-card {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(20px);
    border-radius: 24rpx;
    padding: 28rpx;
    border: 1px solid rgba(255, 255, 255, 0.9);
}

.chart-header {
    margin-bottom: 20rpx;
}

.chart-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #1a1a1a;
}

.chart-container {
    height: 300rpx;
}

.earnings-chart {
    width: 100%;
    height: 100%;
}

/* 加载状态 */
.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 100rpx;
    color: #6b7280;
    font-size: 26rpx;
}

.loading-spinner {
    width: 48rpx;
    height: 48rpx;
    border: 4rpx solid #e5e7eb;
    border-top-color: #16a34a;
    border-radius: 50%;
    margin-bottom: 20rpx;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to {
        transform: rotate(360deg);
    }
}