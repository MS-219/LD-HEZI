page { background: #f5f5f7; min-height: 100vh; }
.container { padding: 0 0 120px 0; }
.custom-nav { display: flex; align-items: center; justify-content: space-between; padding: 0 20px; background: #fff; }
.nav-back { font-size: 24px; color: #333; width: 40px; }
.nav-title { font-size: 18px; font-weight: 600; color: #1a1a1a; }
.nav-placeholder { width: 40px; }

.status-card { display: flex; align-items: center; gap: 12px; padding: 24px 20px; margin: 0 0 12px 0; }
.status-bg-0 { background: linear-gradient(135deg, #fef3c7, #fde68a); }
.status-bg-1 { background: linear-gradient(135deg, #dbeafe, #93c5fd); }
.status-bg-2 { background: linear-gradient(135deg, #ede9fe, #c4b5fd); }
.status-bg-3 { background: linear-gradient(135deg, #dcfce7, #86efac); }
.status-bg-4 { background: linear-gradient(135deg, #fee2e2, #fca5a5); }
.status-emoji { font-size: 32px; }
.status-text-main { font-size: 20px; font-weight: 700; color: #1a1a1a; }

.section-card { background: #fff; margin: 0 16px 12px 16px; border-radius: 16px; padding: 16px 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.03); }
.card-title { font-size: 15px; font-weight: 600; color: #1a1a1a; display: block; margin-bottom: 12px; }

.express-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.express-label { font-size: 13px; color: #9ca3af; }
.express-value { font-size: 14px; color: #374151; font-weight: 500; }
.express-copy-row { display: flex; align-items: center; gap: 8px; }
.copy-btn { font-size: 12px; color: #16a34a; background: rgba(22,163,74,0.1); padding: 2px 10px; border-radius: 20px; font-weight: 500; }

/* 物流时间线 */
.timeline { padding-left: 4px; }
.timeline-item { display: flex; position: relative; padding-bottom: 20px; padding-left: 24px; }
.timeline-item:last-child { padding-bottom: 0; }
.timeline-dot { position: absolute; left: 0; top: 4px; width: 10px; height: 10px; border-radius: 50%; background: #d1d5db; z-index: 1; }
.timeline-active .timeline-dot { background: #16a34a; box-shadow: 0 0 0 4px rgba(22,163,74,0.15); }
.timeline-line { position: absolute; left: 4px; top: 18px; width: 2px; bottom: 0; background: #e5e7eb; }
.timeline-content { flex: 1; }
.timeline-desc { font-size: 14px; color: #374151; display: block; margin-bottom: 2px; }
.timeline-active .timeline-desc { color: #16a34a; font-weight: 600; }
.timeline-time { font-size: 12px; color: #9ca3af; }

.info-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
.info-row:last-child { margin-bottom: 0; }
.info-label { font-size: 13px; color: #9ca3af; flex-shrink: 0; min-width: 70px; }
.info-value { font-size: 14px; color: #374151; text-align: right; flex: 1; word-break: break-all; }
.info-value.mono { font-family: 'Courier New', monospace; font-size: 13px; }
.info-value.highlight { color: #f59e0b; font-weight: 700; }

.product-row { display: flex; gap: 12px; align-items: center; }
.product-thumb { width: 64px; height: 64px; border-radius: 10px; flex-shrink: 0; background: #f3f4f6; }
.product-detail { flex: 1; }
.product-name { font-size: 15px; font-weight: 600; color: #1a1a1a; display: block; }
.product-qty { font-size: 13px; color: #9ca3af; }

.bottom-actions { position: fixed; bottom: 0; left: 0; right: 0; padding: 12px 20px; padding-bottom: calc(12px + env(safe-area-inset-bottom)); background: #fff; border-top: 1px solid #f0f0f0; }
.confirm-btn { background: linear-gradient(135deg, #22c55e, #16a34a) !important; color: #fff !important; border: none !important; border-radius: 50rpx !important; height: 88rpx !important; line-height: 88rpx !important; font-size: 30rpx !important; font-weight: 600 !important; }
