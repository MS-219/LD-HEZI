/**index.wxss**/
page {
  background: linear-gradient(180deg, #e7f6e5 0%, #f5fbf6 44%, #f7f8fb 100%) !important;
  background-attachment: fixed;
  min-height: 100vh;
  color: #17211b;
}

.scrollarea {
  height: calc(100vh - 100px);
}

.container {
  padding: 10px 16px 40px;
  box-sizing: border-box;
}

/* Header */
.home-header {
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  height: 44px;
  padding-top: 48px;
  box-sizing: border-box;
}

.header-logo {
  width: 142px;
  height: 30px;
  display: block;
  flex-shrink: 0;
}

/* Banner */
.banner-wrapper {
  margin: 10px -4px 0;
}

.banner-swiper {
  height: 172px;
}

.banner-item {
  padding: 0 4px;
  box-sizing: border-box;
}

.banner-card {
  width: 100%;
  height: 100%;
  border-radius: 18px;
  overflow: hidden;
  position: relative;
  background: #153d2c;
  box-shadow: 0 14px 32px rgba(17, 103, 55, 0.18);
}

.banner-image {
  width: 100%;
  height: 100%;
  transform: scale(1.01);
}

.banner-fallback {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #0f5138 0%, #178f57 52%, #1fbf79 100%);
}

.banner-shade {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(90deg, rgba(8, 42, 29, 0.74) 0%, rgba(8, 42, 29, 0.18) 58%, rgba(8, 42, 29, 0.42) 100%);
}

.banner-overlay {
  position: absolute;
  left: 18px;
  right: 18px;
  bottom: 18px;
  color: #fff;
}

.banner-title {
  font-size: 21px;
  font-weight: 800;
  display: block;
  line-height: 1.22;
  margin-bottom: 5px;
  letter-spacing: 0;
}

.banner-subtitle {
  font-size: 13px;
  opacity: 0.92;
  font-weight: 500;
  line-height: 1.45;
}

/* Earnings */
.earnings-card {
  margin-top: 18px;
  padding: 20px;
  border-radius: 20px;
  color: #17211b;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #eef9ef 0%, #e3f5e8 52%, #d8f0df 100%);
  border: 1px solid rgba(190, 225, 202, 0.9);
  box-shadow: 0 14px 30px rgba(35, 122, 73, 0.14);
}

.earnings-bg-decoration {
  position: absolute;
  right: -72px;
  top: 0;
  width: 190px;
  height: 100%;
  opacity: 0.58;
  background: linear-gradient(135deg, rgba(22, 163, 74, 0.12) 0%, rgba(14, 165, 233, 0.07) 100%);
  transform: skewX(-18deg);
}

.earnings-content {
  position: relative;
  z-index: 1;
}

.earnings-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20px;
}

.card-kicker {
  display: block;
  color: #6b8a77;
  font-size: 11px;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 5px;
  letter-spacing: 0;
}

.earnings-title {
  display: block;
  color: #13251b;
  font-size: 17px;
  font-weight: 800;
  line-height: 1.25;
  letter-spacing: 0;
}

.live-pill {
  height: 26px;
  padding: 0 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  color: #97630b;
  font-size: 11px;
  font-weight: 600;
  white-space: nowrap;
}

.live-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #fbbf24;
  box-shadow: 0 0 0 3px rgba(251, 191, 36, 0.2);
  margin-right: 6px;
}

.earnings-row {
  display: flex;
  align-items: stretch;
  margin-bottom: 18px;
}

.earnings-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.earnings-item.primary {
  flex: 1.08;
}

.earnings-label {
  font-size: 12px;
  color: #64786c;
  margin-bottom: 8px;
  font-weight: 600;
  line-height: 1.2;
}

.earnings-money {
  display: flex;
  align-items: baseline;
  min-width: 0;
}

.currency {
  color: #8ba091;
  font-size: 15px;
  font-weight: 700;
  margin-right: 4px;
}

.total-currency {
  color: #0f8a63;
}

.earnings-num {
  font-size: 31px;
  font-weight: 800;
  font-family: 'DIN Alternate', sans-serif;
  color: #17211b;
  line-height: 1;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.earnings-num.total {
  color: #0f8a63;
  font-size: 31px;
}

.earnings-divider {
  width: 1px;
  background: rgba(154, 203, 173, 0.48);
  margin: 0 16px;
}

.earnings-footer {
  border-top: 1px solid rgba(154, 203, 173, 0.45);
  padding-top: 12px;
  color: #718177;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 11px;
  line-height: 1.4;
}

.footer-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.footer-left text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.footer-mark {
  width: 4px;
  height: 12px;
  border-radius: 999px;
  background: #fbbf24;
  margin-right: 7px;
  flex-shrink: 0;
}

.refresh-icon {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.58);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #16824e;
  font-size: 13px;
  margin-left: 10px;
  flex-shrink: 0;
}

/* Node Stats */
.node-stats-card,
.system-notice-card {
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border: 1px solid rgba(255, 255, 255, 0.92);
  border-radius: 18px;
  box-shadow: 0 10px 28px rgba(34, 91, 55, 0.08);
}

.node-stats-card {
  padding: 18px;
  margin-top: 16px;
}

.card-title-row,
.card-header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.card-title-row {
  margin-bottom: 17px;
}

.card-title-text {
  display: block;
  font-size: 16px;
  font-weight: 800;
  color: #17211b;
  line-height: 1.25;
  letter-spacing: 0;
}

.card-subtitle {
  display: block;
  font-size: 11px;
  color: #7a897f;
  line-height: 1.3;
  margin-top: 4px;
  letter-spacing: 0;
}

.node-health-chip {
  height: 28px;
  padding: 0 10px;
  border-radius: 999px;
  background: #ecfdf5;
  border: 1px solid #d1fae5;
  color: #16824e;
  display: flex;
  align-items: baseline;
  justify-content: center;
  font-family: 'DIN Alternate', sans-serif;
  flex-shrink: 0;
}

.node-health-main {
  font-size: 16px;
  font-weight: 800;
}

.node-health-sub {
  font-size: 11px;
  font-weight: 700;
  color: #6b8e78;
}

.node-overview {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 14px;
  padding: 16px;
  border-radius: 14px;
  background: linear-gradient(135deg, #f7fbf8 0%, #eef8f2 100%);
  border: 1px solid rgba(211, 237, 220, 0.8);
}

.overview-left {
  min-width: 0;
}

.overview-num {
  font-size: 34px;
  font-weight: 800;
  color: #13251b;
  display: block;
  line-height: 1;
  font-family: 'DIN Alternate', sans-serif;
}

.overview-label {
  font-size: 12px;
  color: #718177;
  margin-top: 6px;
}

.overview-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.mini-chart {
  display: flex;
  align-items: flex-end;
  height: 46px;
}

.bar {
  width: 7px;
  background: #dce7e1;
  border-radius: 999px;
  margin-left: 5px;
}

.bar.active {
  background: linear-gradient(180deg, #38bdf8 0%, #2563eb 100%);
}

.chart-label {
  color: #8a9890;
  font-size: 10px;
  margin-top: 5px;
}

.node-grid {
  display: flex;
  justify-content: space-between;
}

.node-status-item {
  flex: 1;
  min-width: 0;
  height: 76px;
  border-radius: 14px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-right: 8px;
  border: 1px solid transparent;
}

.node-status-item:last-child {
  margin-right: 0;
}

.online-card {
  background: #f0fdf4;
  border-color: #dcfce7;
}

.offline-card {
  background: #f8fafc;
  border-color: #e5e7eb;
}

.partner-card {
  background: #eff6ff;
  border-color: #dbeafe;
}

.node-status-hover {
  opacity: 0.82;
}

.status-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  margin-bottom: 8px;
}

.status-dot.online {
  background: #10b981;
  box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.14);
}

.status-dot.offline {
  background: #94a3b8;
  box-shadow: 0 0 0 3px rgba(148, 163, 184, 0.12);
}

.status-dot.partner {
  background: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.14);
}

.status-num {
  font-size: 18px;
  font-weight: 800;
  color: #17211b;
  margin-bottom: 2px;
  line-height: 1;
  font-family: 'DIN Alternate', sans-serif;
}

.status-label {
  font-size: 11px;
  color: #6b7780;
  line-height: 1.2;
}

/* Notices */
.system-notice-card {
  padding: 18px;
  margin-top: 16px;
}

.card-header-row {
  margin-bottom: 12px;
}

.more-btn {
  height: 28px;
  padding: 0 10px;
  border-radius: 999px;
  background: #f6f8fa;
  color: #657168;
  display: flex;
  align-items: center;
  font-size: 12px;
  font-weight: 600;
  white-space: nowrap;
}

.arrow {
  margin-left: 4px;
  color: #9aa6a0;
}

.notices-list-inner {
  display: flex;
  flex-direction: column;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  padding: 13px 0;
  border-bottom: 1px solid rgba(226, 232, 240, 0.8);
}

.notice-item.is-first {
  margin-bottom: 2px;
  padding: 12px;
  border-radius: 14px;
  border: 1px solid #e2f3e7;
  background: linear-gradient(135deg, #fbfffc 0%, #f1fbf5 100%);
}

.notice-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.notice-item:first-child:not(.is-first) {
  padding-top: 0;
}

.notice-left {
  position: relative;
  margin-right: 12px;
  flex-shrink: 0;
}

.notice-tag {
  position: absolute;
  top: -5px;
  left: -5px;
  background: #f97316;
  color: #fff;
  font-size: 8px;
  padding: 2px 6px;
  border-radius: 999px;
  border: 1px solid #fff;
  box-shadow: 0 4px 10px rgba(249, 115, 22, 0.2);
  z-index: 2;
  font-weight: 800;
  letter-spacing: 0;
}

.notice-thumb {
  width: 46px;
  height: 46px;
  border-radius: 12px;
  background: #f3f4f6;
}

.notice-icon-placeholder {
  width: 46px;
  height: 46px;
  border-radius: 12px;
  background: linear-gradient(135deg, #e0f2fe 0%, #eef2ff 100%);
  color: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 800;
}

.notice-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 46px;
}

.notice-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 5px;
}

.notice-title {
  flex: 1;
  min-width: 0;
  font-size: 14px;
  font-weight: 700;
  color: #17211b;
  line-height: 1.36;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 8px;
}

.notice-time {
  font-size: 10px;
  color: #97a39d;
  line-height: 1.5;
  white-space: nowrap;
  flex-shrink: 0;
}

.notice-summary {
  font-size: 12px;
  color: #69766e;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  line-clamp: 1;
  overflow: hidden;
  line-height: 1.45;
}

.notice-empty {
  height: 72px;
  border-radius: 14px;
  background: #f8fafc;
  color: #94a3b8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
}
