page {
    background: #f5f5f5;
    min-height: 100vh;
}

.container {
    padding: 0 24rpx 40rpx;
}

.custom-nav {
    display: flex;
    align-items: center;
    padding-bottom: 20rpx;
    background: #fff;
    margin: 0 -24rpx;
    padding-left: 24rpx;
    padding-right: 24rpx;
}

.nav-back {
    width: 60px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
}

.back-icon {
    font-size: 28px;
    color: #1a1a1a;
    font-weight: 300;
}

.nav-title {
    flex: 1;
    font-size: 36rpx;
    font-weight: 600;
    color: #1a1a1a;
    text-align: center;
    margin-right: 60px;
}

/* 分区 */
.section {
    background: #fff;
    border-radius: 16rpx;
    padding: 32rpx;
    margin-top: 24rpx;
}

.section-title {
    font-size: 28rpx;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 24rpx;
}

/* 类型选择 */
.type-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16rpx;
}

.type-item {
    text-align: center;
    padding: 20rpx 0;
    font-size: 26rpx;
    color: #666;
    background: #f5f5f5;
    border-radius: 12rpx;
    border: 2rpx solid transparent;
}

.type-item.active {
    background: rgba(22, 163, 74, 0.1);
    color: #16a34a;
    border-color: #16a34a;
    font-weight: 500;
}

/* 内容输入 */
.content-input {
    width: 100%;
    height: 240rpx;
    background: #f8f9fa;
    border-radius: 12rpx;
    padding: 24rpx;
    font-size: 28rpx;
    color: #333;
    box-sizing: border-box;
}

.word-count {
    text-align: right;
    font-size: 24rpx;
    color: #999;
    margin-top: 12rpx;
}

/* 图片上传 */
.image-grid {
    display: flex;
    gap: 16rpx;
    flex-wrap: wrap;
}

.image-item {
    position: relative;
    width: 160rpx;
    height: 160rpx;
    border-radius: 12rpx;
    overflow: hidden;
}

.image-item image {
    width: 100%;
    height: 100%;
}

.remove-btn {
    position: absolute;
    top: 0;
    right: 0;
    width: 40rpx;
    height: 40rpx;
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
    font-size: 28rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0 12rpx 0 12rpx;
}

.add-image {
    width: 160rpx;
    height: 160rpx;
    background: #f8f9fa;
    border: 2rpx dashed #ddd;
    border-radius: 12rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8rpx;
}

.add-icon {
    font-size: 48rpx;
    color: #999;
}

.add-text {
    font-size: 22rpx;
    color: #999;
}

/* 联系方式 */
.contact-input {
    width: 100%;
    height: 88rpx;
    background: #f8f9fa;
    border-radius: 12rpx;
    padding: 0 24rpx;
    font-size: 28rpx;
    color: #333;
    box-sizing: border-box;
}

/* 提交按钮 */
.submit-section {
    margin-top: 60rpx;
    padding: 0 24rpx;
}

.submit-btn {
    width: 100%;
    height: 96rpx;
    background: linear-gradient(135deg, #16a34a, #15803d);
    color: #fff;
    font-size: 32rpx;
    font-weight: 600;
    border-radius: 48rpx;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
}

.submit-btn.disabled {
    opacity: 0.6;
}

.submit-btn::after {
    border: none;
}