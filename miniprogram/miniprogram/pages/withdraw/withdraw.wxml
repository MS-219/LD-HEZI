<view class="container">
    <view class="header-actions">
        <view class="nav-right" bindtap="goRecords">提现记录</view>
    </view>
    <!-- 余额卡片 -->
    <view class="balance-card">
        <view class="balance-header">
            <text class="balance-label">可回收算力值</text>
        </view>
        <view class="balance-amount">
            <text class="currency">⚡</text>
            <text class="amount">{{walletInfo.hashrateBalance}}</text>
        </view>
        <view class="exchange-info">
            <text class="exchange-rate">
                ≈ {{walletInfo.available}} U（{{hashratePerYuan}}算力值=1U）
            </text>
        </view>
        <view class="balance-info">
            <text>累计算力值: ⚡{{walletInfo.totalHashrate}}</text>
            <text>待审核: {{walletInfo.pending}} U</text>
        </view>
    </view>
    <!-- 提现日期限制提示 -->
    <view class="withdraw-limit-card top-limit" wx:if="{{!canWithdraw && withdrawMessage}}">
        <view class="limit-icon">📅</view>
        <view class="limit-content">
            <text class="limit-title">暂不可提现</text>
            <text class="limit-message">{{withdrawMessage}}</text>
        </view>
    </view>
    <!-- 提现表单 -->
    <view class="form-card">
        <view class="form-title">提现信息</view>
        <view class="form-item">
            <text class="form-label">提现方式</text>
            <view class="type-options">
                <view class="type-option {{form.type === 1 ? 'active' : ''}}" bindtap="selectType" data-type="1" wx:if="{{false}}">
                    <text class="type-icon">💳</text>
                    <text>微信</text>
                </view>
                <view class="type-option {{form.type === 2 ? 'active' : ''}}" bindtap="selectType" data-type="2" wx:if="{{false}}">
                    <text class="type-icon">📱</text>
                    <text>支付宝</text>
                </view>
                <view class="type-option {{form.type === 3 ? 'active' : ''}}" bindtap="selectType" data-type="3">
                    <text class="type-icon">🏦</text>
                    <text>银行卡</text>
                </view>
            </view>
        </view>
        <view class="form-item">
            <text class="form-label">提现金额</text>
            <view class="amount-input">
                <text class="input-prefix">U</text>
                <input type="digit" placeholder="请输入提现金额" value="{{form.amount}}" bindinput="onAmountInput" />
            </view>
            <view class="quick-amounts">
                <view class="quick-btn" bindtap="setAmount" data-amount="50">50U</view>
                <view class="quick-btn" bindtap="setAmount" data-amount="100">100U</view>
                <view class="quick-btn" bindtap="setAmount" data-amount="200">200U</view>
                <view class="quick-btn all" bindtap="setAllAmount">全部提现</view>
            </view>
        </view>
        <view class="form-item" wx:if="{{form.type === 2 || form.type === 3}}">
            <text class="form-label">{{form.type === 2 ? '支付宝账号' : '银行卡号'}}</text>
            <view class="account-input-row">
                <input class="form-input account-input" placeholder="{{form.type === 2 ? '请输入支付宝账号(手机号/邮箱)' : '请输入银行卡号'}}" value="{{form.account}}" bindinput="onAccountInput" />
            </view>
        </view>
        <view class="form-item" wx:if="{{form.type === 1}}">
            <text class="form-label">收款二维码</text>
            <view class="qr-upload-box" bindtap="uploadQRCode">
                <image class="qr-preview" src="{{form.qrCode}}" mode="aspectFit" wx:if="{{form.qrCode}}"></image>
                <view class="upload-placeholder" wx:else>
                    <text class="upload-icon">+</text>
                    <text class="upload-text">点击上传收款码</text>
                </view>
            </view>
            <text class="qr-tip">上传后将自动保存，下次提现无需重复上传</text>
        </view>
        <view class="form-item">
            <text class="form-label">收款人姓名</text>
            <input class="form-input" placeholder="请输入收款人真实姓名" value="{{form.realName}}" bindinput="onRealNameInput" />
        </view>
    </view>
    <!-- 提示信息 -->
    <view class="tips-card">
        <view class="tips-title">温馨提示</view>
        <view class="tips-content">
            <text class="tips-highlight">⚡ 回收比例：{{hashratePerYuan}} 算力值 = 1 U</text>
            <text>1. 最低提现金额为 {{minWithdraw}} U</text>
            <text>2. 提现审核通过后由平台安排打款</text>
            <text>3. 提现申请将在 1-3 个工作日内处理</text>
        </view>
    </view>
    <!-- 提交按钮 -->
    <view class="submit-section">
        <view class="preview-info">
            <text>预计到账</text>
            <text class="preview-amount">{{previewAmount}} U</text>
        </view>
        <button class="submit-btn {{(!canWithdraw || !walletReady) ? 'disabled' : ''}}" bindtap="submitWithdraw" loading="{{submitting}}" disabled="{{!canWithdraw || !walletReady || submitting}}">
            {{!canWithdraw ? '限制提现日' : !walletReady ? '余额刷新中...' : submitting ? '提交中...' : '确认提现'}}
        </button>
    </view>
</view>
