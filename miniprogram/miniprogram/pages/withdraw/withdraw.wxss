page {
    background: linear-gradient(180deg, #DEF1DD 0%, #f0fdf4 50%, #f7f7f9 100%);
    min-height: 100vh;
}

.container {
    padding: 10px 20px 180px 20px;
    box-sizing: border-box;
}

.header-actions {
    display: flex;
    justify-content: flex-end;
    padding: 0 5px 8px 0;
}

.nav-right {
    font-size: 14px;
    color: #666;
    padding: 5px 0;
}

/* Balance Card */
.balance-card {
    background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
    border-radius: 20px;
    padding: 20px 24px;
    color: #fff;
    margin-top: 0;
    margin-bottom: 15px;
    box-shadow: 0 10px 30px rgba(22, 163, 74, 0.25);
}

.balance-header {
    margin-bottom: 8px;
}

.balance-label {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
}

.balance-amount {
    display: flex;
    align-items: baseline;
    margin-bottom: 16px;
}

.currency {
    font-size: 20px;
    font-weight: 600;
}

.amount {
    font-size: 40px;
    font-weight: 700;
    margin-left: 4px;
}

.balance-info {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.7);
    padding-top: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
}

/* 兑换比例信息 */
.exchange-info {
    margin-bottom: 12px;
}

.exchange-rate {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.15);
    padding: 6px 12px;
    border-radius: 20px;
    display: inline-block;
}

/* Form Card */
.form-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    margin-bottom: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
}

.form-title {
    font-size: 16px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 20px;
}

.form-item {
    margin-bottom: 20px;
}

.form-label {
    font-size: 14px;
    color: #6b7280;
    margin-bottom: 10px;
    display: block;
}

.type-options {
    display: flex;
    gap: 12px;
}

.type-option {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 12px;
    background: #f9fafb;
    border-radius: 12px;
    border: 2px solid transparent;
    transition: all 0.2s;
}

.type-option.active {
    background: #f0fdf4;
    border-color: #16a34a;
}

.type-icon {
    font-size: 24px;
    margin-bottom: 4px;
}

.type-option text:last-child {
    font-size: 12px;
    color: #374151;
}

.amount-input {
    display: flex;
    align-items: center;
    background: #f9fafb;
    border-radius: 12px;
    padding: 0 16px;
}

.input-prefix {
    font-size: 20px;
    color: #16a34a;
    font-weight: 600;
}

.amount-input input {
    flex: 1;
    height: 50px;
    font-size: 24px;
    font-weight: 600;
    color: #1a1a1a;
}

.quick-amounts {
    display: flex;
    gap: 8px;
    margin-top: 12px;
}

.quick-btn {
    flex: 1;
    padding: 8px 0;
    background: #f3f4f6;
    border-radius: 8px;
    text-align: center;
    font-size: 13px;
    color: #374151;
}

.quick-btn.all {
    background: #e0f2fe;
    color: #0369a1;
}

.form-input {
    width: 100%;
    height: 50px;
    background: #f9fafb;
    border-radius: 12px;
    padding: 0 16px;
    font-size: 15px;
    box-sizing: border-box;
}

/* QR Code Upload */
.qr-upload-box {
    width: 100%;
    height: 160px;
    background: #f9fafb;
    border: 2rpx dashed #d1d5db;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
}

.qr-preview {
    width: 100%;
    height: 100%;
}

.upload-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
}

.upload-icon {
    font-size: 40px;
    color: #9ca3af;
    line-height: 1;
}

.upload-text {
    font-size: 13px;
    color: #9ca3af;
}

.qr-tip {
    display: block;
    font-size: 12px;
    color: #9ca3af;
    margin-top: 8px;
    text-align: center;
}

/* Tips Card */
.tips-card {
    background: #fff;
    border-radius: 16px;
    padding: 18px;
    margin-bottom: 20px;
    box-shadow: 0 4px 15px rgba(245, 158, 11, 0.05);
    border: 1px solid rgba(245, 158, 11, 0.1);
}

.tips-title {
    font-size: 15px;
    font-weight: 700;
    color: #92400e;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
}

.tips-title::before {
    content: '💡';
    margin-right: 6px;
    font-size: 16px;
}

.tips-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.tips-content text {
    font-size: 13px;
    color: #b45309;
    line-height: 1.5;
}

.tips-highlight {
    font-size: 14px !important;
    font-weight: 700;
    color: #16a34a !important;
    background: #f0fdf4;
    padding: 8px 12px;
    border-radius: 10px;
    margin-bottom: 4px;
    border: 1px solid rgba(22, 163, 74, 0.1);
}

/* Submit Section */
.submit-section {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: #fff;
    padding: 16px 20px;
    padding-bottom: calc(16px + env(safe-area-inset-bottom));
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.05);
}

.preview-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    font-size: 14px;
    color: #6b7280;
}

.preview-amount {
    font-size: 20px;
    font-weight: 700;
    color: #16a34a;
}

.submit-btn {
    width: 100%;
    height: 50px;
    background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    border-radius: 12px;
    border: none;
    margin: 0;
}

.submit-btn[loading] {
    opacity: 0.7;
}

/* 提现日期限制卡片 */
.withdraw-limit-card {
    width: 100%;
    box-sizing: border-box;
    margin: 10px 0 20px 0;
    padding: 16px 18px;
    background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
    border-radius: 16px;
    display: flex;
    align-items: center;
    border: 1px solid rgba(245, 158, 11, 0.1);
    box-shadow: 0 8px 20px rgba(245, 158, 11, 0.05);
}

.top-limit {
    margin: 0 0 12px 0 !important;
}

.contract-card {
    width: 100%;
    box-sizing: border-box;
    margin: 0 0 15px 0;
    padding: 14px 16px;
    background: linear-gradient(135deg, #f5f7ff 0%, #eef2ff 100%);
    border-radius: 16px;
    display: flex;
    flex-direction: row;
    align-items: center;
    border: 1px solid rgba(79, 70, 229, 0.08);
    box-shadow: 0 8px 20px rgba(79, 70, 229, 0.06);
    position: relative;
    overflow: hidden;
}

/* 添加一个微妙的背景装饰 */
.contract-card::after {
    content: '';
    position: absolute;
    right: -20px;
    top: -20px;
    width: 60px;
    height: 60px;
    background: rgba(79, 70, 229, 0.04);
    border-radius: 50%;
}

.limit-icon {
    width: 34px;
    height: 34px;
    background: #fff;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    margin-right: 12px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.03);
    flex-shrink: 0;
}

.limit-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    margin-right: 8px;
}

.limit-title {
    font-size: 15px;
    font-weight: 700;
    color: #312e81;
    display: block;
    margin-bottom: 2px;
    line-height: 1.2;
    white-space: nowrap;
}

.limit-message {
    font-size: 11px;
    color: #6366f1;
    opacity: 0.85;
    line-height: 1.3;
}

.contract-btn {
    flex-shrink: 0;
    margin: 0;
    margin-left: 10px;
    background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
    color: #ffffff;
    font-size: 13px;
    font-weight: 600;
    padding: 0 14px;
    height: 32px;
    line-height: 32px;
    border-radius: 16px;
    box-shadow: 0 4px 12px rgba(79, 70, 229, 0.25);
    border: none;
    min-width: 70px;
    transition: all 0.2s;
}

.contract-btn:active {
    transform: scale(0.96);
    opacity: 0.9;
}

/* 禁用状态按钮 */
.submit-btn.disabled {
    background: linear-gradient(135deg, #9ca3af 0%, #6b7280 100%) !important;
    opacity: 0.8;
}

/* ========== 账号输入行样式 ========== */
.account-input-row {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
}

.account-input-row .account-input {
    flex: 1;
    width: 0;
    min-width: 0;
}

.edit-card-btn {
    background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
    color: #fff;
    font-size: 12px;
    font-weight: 500;
    padding: 8px 14px;
    border-radius: 8px;
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(79, 70, 229, 0.25);
}

/* ========== 修改卡号弹窗样式 ========== */
.modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
}

.modal-content {
    width: 85%;
    max-width: 340px;
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
}

.modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    border-bottom: 1px solid #f3f4f6;
}

.modal-title {
    font-size: 17px;
    font-weight: 600;
    color: #1a1a1a;
}

.modal-close {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: #9ca3af;
    border-radius: 50%;
    background: #f3f4f6;
}

.modal-body {
    padding: 20px;
}

.form-group {
    margin-bottom: 18px;
}

.form-group:last-of-type {
    margin-bottom: 12px;
}

.radio-row {
    display: flex;
    gap: 12px;
    margin-top: 8px;
}

.radio-item {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 12px;
    background: #f9fafb;
    border-radius: 12px;
    border: 2px solid transparent;
    font-size: 14px;
    color: #374151;
    transition: all 0.2s;
}

.radio-item.active {
    background: #f0fdf4;
    border-color: #16a34a;
    color: #15803d;
}

.radio-icon {
    font-size: 18px;
}

.modal-input {
    width: 100%;
    height: 48px;
    background: #f9fafb;
    border-radius: 12px;
    padding: 0 16px;
    font-size: 15px;
    box-sizing: border-box;
    margin-top: 8px;
}

.modal-tips {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 12px;
    padding: 12px;
    background: #fffbeb;
    border-radius: 10px;
}

.modal-tips text {
    font-size: 12px;
    color: #b45309;
    line-height: 1.4;
}

.modal-footer {
    display: flex;
    gap: 12px;
    padding: 16px 20px 24px;
}

.modal-btn {
    flex: 1;
    height: 44px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 500;
    margin: 0;
    padding: 0;
    border: none;
}

.modal-btn.cancel {
    background: #f3f4f6;
    color: #6b7280;
}

.modal-btn.confirm {
    background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
    color: #fff;
}
