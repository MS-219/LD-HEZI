.container {
    min-height: 100vh;
    background-color: #f8f9ff;
    display: flex;
    flex-direction: column;
}

.nav-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
}

.nav-title {
    font-size: 34rpx;
    font-weight: 600;
    color: #333333;
}

.content {
    flex: 1;
    padding: 60rpx 40rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
}

/* 头部提示 */
.header-tip {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 60rpx;
    text-align: center;
}

.tip-emoji {
    font-size: 100rpx;
    margin-bottom: 20rpx;
}

.tip-title {
    font-size: 40rpx;
    font-weight: 600;
    color: #333333;
    margin-bottom: 12rpx;
}

.tip-desc {
    font-size: 28rpx;
    color: #999999;
}

/* 头像选择 - 保持正圆 */
.avatar-section {
    display: flex;
    justify-content: center;
    margin-bottom: 80rpx;
    width: 100%;
}

.avatar-wrapper {
    position: relative;
    width: 200rpx;
    height: 200rpx;
}

.avatar-btn {
    width: 200rpx !important;
    height: 200rpx !important;
    border-radius: 100rpx !important;
    padding: 0 !important;
    margin: 0 !important;
    background: #ffffff !important;
    border: 4rpx solid #eeeeee !important;
    overflow: hidden !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.05);
}

.avatar-btn::after {
    border: none !important;
}

.avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.avatar-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #cccccc;
}

.placeholder-icon {
    font-size: 60rpx;
    margin-bottom: 4rpx;
}

.placeholder-text {
    font-size: 20rpx;
}

.avatar-edit-badge {
    position: absolute;
    bottom: 0;
    right: 0;
    background: #667eea;
    color: #fff;
    font-size: 20rpx;
    padding: 4rpx 14rpx;
    border-radius: 20rpx;
    box-shadow: 0 4rpx 10rpx rgba(102, 126, 234, 0.3);
    z-index: 10;
}

/* 表单区域 */
.form-card {
    width: 100%;
    background: #ffffff;
    border-radius: 32rpx;
    padding: 48rpx;
    box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.03);
    box-sizing: border-box;
    margin-bottom: 80rpx;
}

.nickname-section {
    width: 100%;
}

.input-label {
    font-size: 26rpx;
    color: #999999;
    margin-bottom: 24rpx;
    display: block;
}

.nickname-input {
    width: 100%;
    height: 80rpx;
    font-size: 32rpx;
    color: #333333;
    border-bottom: 2rpx solid #f5f5f5;
    padding-bottom: 10rpx;
}

.placeholder-style {
    color: #cccccc;
}

/* 操作按钮 */
.action-buttons {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 20rpx;
}

.save-btn {
    width: 100% !important;
    height: 96rpx !important;
    line-height: 96rpx !important;
    background: linear-gradient(135deg, #667eea, #764ba2) !important;
    color: #ffffff !important;
    font-size: 32rpx !important;
    font-weight: 600 !important;
    border-radius: 48rpx !important;
    border: none !important;
    box-shadow: 0 10rpx 20rpx rgba(102, 126, 234, 0.2) !important;
}

.save-btn.disabled {
    background: #cccccc !important;
    box-shadow: none !important;
}

.skip-btn {
    width: 100% !important;
    background: transparent !important;
    color: #999999 !important;
    font-size: 28rpx !important;
    margin-top: 10rpx !important;
}