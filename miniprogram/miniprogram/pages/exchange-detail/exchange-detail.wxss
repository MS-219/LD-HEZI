page { background: #f7f7f9; min-height: 100vh; }
.container { padding: 0 0 160px 0; }
.custom-nav { display: flex; align-items: center; justify-content: space-between; padding: 0 20px; margin-bottom: 0; background: #fff; }
.nav-back { font-size: 24px; color: #333; width: 40px; }
.nav-title { font-size: 18px; font-weight: 600; color: #1a1a1a; }
.nav-placeholder { width: 40px; }

.detail-image { width: 100%; height: 500rpx; display: block; }

.detail-card, .price-table-card, .address-card, .qty-card {
    background: #fff; margin: 12px 16px; border-radius: 16px; padding: 16px 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.03);
}
.card-title { font-size: 15px; font-weight: 600; color: #1a1a1a; display: block; margin-bottom: 12px; }
.detail-name { font-size: 20px; font-weight: 700; color: #1a1a1a; display: block; margin-bottom: 8px; }
.detail-price-row { display: flex; align-items: baseline; gap: 4px; margin-bottom: 10px; }
.detail-price-icon { font-size: 18px; }
.detail-price-value { font-size: 28px; font-weight: 800; color: #f59e0b; }
.detail-price-unit { font-size: 13px; color: #92400e; }
.detail-price-yuan { font-size: 14px; color: #9ca3af; margin-left: 8px; }
.detail-desc { font-size: 14px; color: #6b7280; line-height: 1.6; display: block; }

/* 价格表 */
.price-table { display: flex; flex-direction: column; gap: 0; }
.price-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 12px; border-radius: 10px; }
.price-row-active { background: linear-gradient(135deg, #f0fdf4, #dcfce7); }
.price-level-name { font-size: 14px; font-weight: 500; color: #374151; min-width: 50px; }
.price-values { display: flex; align-items: baseline; gap: 8px; }
.price-hashrate { font-size: 15px; font-weight: 700; color: #f59e0b; }
.price-rmb { font-size: 12px; color: #9ca3af; }
.price-current-badge { font-size: 11px; color: #16a34a; background: rgba(22,163,74,0.1); padding: 2px 8px; border-radius: 20px; font-weight: 600; }

/* 地址 */
.address-card { position: relative; }
.address-content { }
.address-info { display: flex; align-items: center; gap: 12px; margin-bottom: 4px; }
.address-name { font-size: 15px; font-weight: 600; color: #1a1a1a; }
.address-phone { font-size: 14px; color: #6b7280; }
.address-detail { font-size: 13px; color: #9ca3af; line-height: 1.4; }
.address-empty-text { font-size: 14px; color: #9ca3af; }
.address-arrow { position: absolute; right: 20px; top: 50%; transform: translateY(-50%); font-size: 20px; color: #ccc; }

/* 数量 */
.qty-card { display: flex; justify-content: space-between; align-items: center; }
.qty-control { display: flex; align-items: center; gap: 16px; }
.qty-btn { width: 32px; height: 32px; border-radius: 8px; background: #f3f4f6; display: flex; align-items: center; justify-content: center; font-size: 18px; color: #374151; font-weight: 600; }
.qty-value { font-size: 18px; font-weight: 700; color: #1a1a1a; min-width: 30px; text-align: center; }

/* 底部栏 */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 12px 20px; padding-bottom: calc(12px + env(safe-area-inset-bottom)); display: flex; align-items: center; justify-content: space-between; border-top: 1px solid #f0f0f0; z-index: 100; }
.bottom-info { display: flex; align-items: baseline; gap: 4px; }
.bottom-label { font-size: 14px; color: #6b7280; }
.bottom-total { font-size: 22px; font-weight: 800; color: #f59e0b; }
.exchange-btn { flex-shrink: 0; background: linear-gradient(135deg, #22c55e, #16a34a) !important; color: #fff !important; border: none !important; border-radius: 50rpx !important; padding: 0 50rpx !important; height: 88rpx !important; line-height: 88rpx !important; font-size: 30rpx !important; font-weight: 600 !important; }
.btn-disabled { background: #d1d5db !important; }

/* 地址弹窗 */
.address-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 200; }
.address-popup { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-radius: 20px 20px 0 0; z-index: 201; max-height: 60vh; display: flex; flex-direction: column; transform: translateY(100%); transition: transform 0.3s ease; }
.popup-show { transform: translateY(0); }
.popup-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; border-bottom: 1px solid #f0f0f0; }
.popup-title { font-size: 16px; font-weight: 600; }
.popup-close { font-size: 18px; color: #999; padding: 4px; }
.popup-list { flex: 1; overflow-y: auto; padding: 8px 16px; }
.popup-addr-item { padding: 12px 16px; border-radius: 12px; margin-bottom: 8px; background: #f9fafb; }
.addr-active { background: #f0fdf4; border: 1px solid #86efac; }
.popup-addr-info { display: flex; align-items: center; gap: 10px; margin-bottom: 4px; }
.popup-addr-name { font-size: 15px; font-weight: 600; }
.popup-addr-phone { font-size: 13px; color: #6b7280; }
.popup-addr-default { font-size: 11px; color: #16a34a; background: rgba(22,163,74,0.1); padding: 2px 6px; border-radius: 10px; }
.popup-addr-detail { font-size: 13px; color: #9ca3af; }
.popup-add { padding: 16px 20px; border-top: 1px solid #f0f0f0; padding-bottom: calc(16px + env(safe-area-inset-bottom)); }
.popup-add-text { font-size: 15px; color: #16a34a; font-weight: 500; text-align: center; display: block; }
