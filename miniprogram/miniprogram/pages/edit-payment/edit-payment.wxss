page {
    background: linear-gradient(180deg, #e8f5e9 0%, #f0fdf4 40%, #f7f7f9 100%);
    min-height: 100vh;
}

.container {
    padding-bottom: 60px;
}

/* ========== 导航栏 ========== */
.custom-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent;
    padding-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.nav-back {
    position: absolute;
    left: 12px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.7);
    border-radius: 50%;
    backdrop-filter: blur(10px);
}

.back-icon {
    font-size: 22px;
    color: #1a1a1a;
    font-weight: 300;
}

.nav-title {
    font-size: 17px;
    font-weight: 600;
    color: #1a1a1a;
}

/* ========== 顶部银行卡卡片 ========== */
.hero-card {
    margin: 8px 20px 20px;
    background: linear-gradient(135deg, #15803d 0%, #16a34a 50%, #22c55e 100%);
    border-radius: 20px;
    padding: 24px 22px;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(22, 163, 74, 0.3);
}

.hero-card::before {
    content: '';
    position: absolute;
    right: -30px;
    top: -30px;
    width: 120px;
    height: 120px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 50%;
}

.hero-card::after {
    content: '';
    position: absolute;
    right: 30px;
    bottom: -40px;
    width: 80px;
    height: 80px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
}

.hero-icon-wrap {
    width: 48px;
    height: 48px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 14px;
    flex-shrink: 0;
    backdrop-filter: blur(10px);
}

.hero-icon {
    font-size: 24px;
}

.hero-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
}

.hero-name {
    font-size: 17px;
    font-weight: 700;
    color: #ffffff;
}

.hero-card-no {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
    letter-spacing: 1px;
}

.hero-badge {
    position: absolute;
    top: 14px;
    right: 16px;
    display: flex;
    align-items: center;
    gap: 5px;
    background: rgba(255, 255, 255, 0.2);
    padding: 4px 12px;
    border-radius: 20px;
    backdrop-filter: blur(10px);
}

.badge-dot {
    width: 6px;
    height: 6px;
    background: #bbf7d0;
    border-radius: 50%;
}

.badge-text {
    font-size: 11px;
    color: #ffffff;
    font-weight: 600;
}

.badge-grey {
    background: rgba(255, 255, 255, 0.15);
}

/* ========== 区域通用 ========== */
.section {
    margin: 0 20px 20px;
}

.section-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
}

.section-icon {
    font-size: 18px;
}

.section-title {
    font-size: 16px;
    font-weight: 700;
    color: #1a1a1a;
}

/* ========== 输入卡片 ========== */
.input-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 18px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
    margin-bottom: 16px;
}

.input-label {
    display: block;
    font-size: 13px;
    color: #6b7280;
    margin-bottom: 10px;
    font-weight: 500;
}

.card-input {
    width: 100%;
    height: 48px;
    background: #f8fafb;
    border-radius: 12px;
    padding: 0 16px;
    font-size: 16px;
    color: #1a1a1a;
    box-sizing: border-box;
    border: 1.5px solid #e5e7eb;
    transition: border-color 0.2s;
    letter-spacing: 1px;
}

.card-input:focus {
    border-color: #16a34a;
}

/* ========== 主按钮 ========== */
.primary-btn {
    width: 100%;
    height: 48px;
    background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
    color: #ffffff;
    font-size: 16px;
    font-weight: 600;
    border-radius: 14px;
    border: none;
    margin: 0 0 14px 0;
    padding: 0;
    box-shadow: 0 4px 16px rgba(22, 163, 74, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
}

.primary-btn:active {
    transform: scale(0.98);
    opacity: 0.9;
}

.btn-disabled {
    background: linear-gradient(135deg, #d1d5db 0%, #9ca3af 100%) !important;
    box-shadow: none !important;
}

/* ========== 提示 ========== */
.tips-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.tip-item {
    font-size: 12px;
    color: #9ca3af;
    line-height: 1.6;
}

/* ========== 底部安全提示 ========== */
.safe-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 24px 0 40px;
}

.safe-icon {
    font-size: 14px;
}

.safe-text {
    font-size: 12px;
    color: #c0c5cc;
    font-weight: 500;
}

/* ========== 待审核提示 ========== */
.pending-banner {
    margin: 0 20px 16px;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 12px;
    padding: 12px 16px;
    display: flex;
    align-items: flex-start;
    gap: 8px;
    box-shadow: 0 2px 8px rgba(245, 158, 11, 0.1);
}

.pending-icon {
    font-size: 16px;
    margin-top: 2px;
}

.pending-text {
    flex: 1;
    font-size: 13px;
    color: #d97706;
    line-height: 1.5;
}
