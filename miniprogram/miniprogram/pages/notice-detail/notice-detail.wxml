<view class="container">
    <!-- 自定义导航栏 -->
    <view class="nav-bar" style="padding-top: {{navBarTop}}px;">
        <view class="nav-content" style="height: {{navBarHeight}}px;">
            <view class="back-btn" bindtap="goBack">
                <text class="back-icon">←</text>
            </view>
            <text class="nav-title">公告详情</text>
            <view class="placeholder"></view>
        </view>
    </view>
    <!-- 内容区域 -->
    <view class="content-area" wx:if="{{notice && !loading}}">
        <!-- 公告标题 -->
        <view class="notice-header">
            <text class="notice-title">{{notice.title}}</text>
            <text class="notice-time">{{notice.publishTime}}</text>
        </view>
        <!-- 公告图片 -->
        <image wx:if="{{notice.imageUrl}}" class="notice-image" src="{{notice.imageUrl}}" mode="widthFix"></image>
        <!-- 公告内容 -->
        <view class="notice-content">
            <text>{{notice.content}}</text>
        </view>
    </view>
    <!-- 加载中 -->
    <view class="loading" wx:if="{{loading}}">
        <text>加载中...</text>
    </view>
</view>