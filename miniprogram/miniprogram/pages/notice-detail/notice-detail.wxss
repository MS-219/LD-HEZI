.container {
    min-height: 100vh;
    background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
}

/* 导航栏 */
.nav-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
}

.nav-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
}

.back-btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.back-icon {
    font-size: 24px;
    color: #fff;
    font-weight: bold;
}

.nav-title {
    font-size: 17px;
    font-weight: 600;
    color: #fff;
}

.placeholder {
    width: 44px;
}

/* 内容区域 */
.content-area {
    padding: 100px 16px 24px;
}

/* 公告头部 */
.notice-header {
    background: #fff;
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 16px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.notice-title {
    font-size: 20px;
    font-weight: 700;
    color: #1a1a2e;
    display: block;
    margin-bottom: 12px;
    line-height: 1.4;
}

.notice-time {
    font-size: 13px;
    color: #9ca3af;
}

/* 公告图片 */
.notice-image {
    width: 100%;
    border-radius: 12px;
    margin-bottom: 16px;
}

/* 公告内容 */
.notice-content {
    background: #fff;
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.notice-content text {
    font-size: 15px;
    line-height: 1.8;
    color: #374151;
    white-space: pre-wrap;
}

/* 加载中 */
.loading {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 200px;
    color: #9ca3af;
    font-size: 14px;
}