page {
    background: linear-gradient(180deg, #DEF1DD 0%, #f0fdf4 30%, #f5f5f5 100%);
    min-height: 100vh;
}

.container {
    padding: 0 24rpx 40rpx;
}

/* 导航栏 */
.custom-nav {
    display: flex;
    align-items: center;
    padding-bottom: 20rpx;
}

.nav-back {
    width: 60px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
}

.back-icon {
    font-size: 28px;
    color: #1a1a1a;
    font-weight: 300;
}

.nav-title {
    flex: 1;
    font-size: 36rpx;
    font-weight: 600;
    color: #1a1a1a;
    text-align: center;
    margin-right: 60px;
}

/* 总览卡片 */
.summary-card {
    background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
    border-radius: 24rpx;
    padding: 40rpx 32rpx;
    margin-bottom: 24rpx;
    box-shadow: 0 10rpx 30rpx rgba(22, 163, 74, 0.25);
    color: #fff;
}

.summary-header {
    text-align: center;
    margin-bottom: 32rpx;
}

.summary-title {
    display: block;
    font-size: 36rpx;
    font-weight: 600;
    margin-bottom: 8rpx;
}

.summary-subtitle {
    font-size: 24rpx;
    opacity: 0.8;
}

.summary-stats {
    display: flex;
    align-items: center;
    justify-content: space-around;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 16rpx;
    padding: 28rpx 16rpx;
}

.stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
}

.stat-num {
    font-size: 44rpx;
    font-weight: 700;
    margin-bottom: 8rpx;
}

.stat-num.online {
    color: #4ade80;
}

.stat-num.offline {
    color: #fbbf24;
}

.stat-label {
    font-size: 22rpx;
    opacity: 0.8;
}

.stat-divider {
    width: 2rpx;
    height: 50rpx;
    background: rgba(255, 255, 255, 0.3);
}

.status-row {
    display: flex;
    align-items: center;
    gap: 8rpx;
}

.status-dot {
    width: 14rpx;
    height: 14rpx;
    border-radius: 50%;
}

.status-dot.online {
    background: #4ade80;
    box-shadow: 0 0 8rpx rgba(74, 222, 128, 0.6);
}

.status-dot.offline {
    background: #fbbf24;
}

/* 可点击的统计项 */
.stat-item.clickable {
    padding: 12rpx 8rpx;
    margin: -12rpx -8rpx;
    border-radius: 12rpx;
    transition: background 0.2s ease;
}

.stat-item.clickable:active {
    background: rgba(255, 255, 255, 0.2);
}

/* 成员列表卡片 */
.members-card {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(20px);
    border-radius: 24rpx;
    padding: 32rpx;
    margin-bottom: 24rpx;
    border: 1px solid rgba(255, 255, 255, 0.8);
}

.card-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 32rpx;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 24rpx;
}

.member-count {
    font-size: 24rpx;
    color: #6b7280;
    font-weight: normal;
}

.members-list {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
}

.member-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #fff;
    padding: 24rpx;
    border-radius: 16rpx;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.member-item:active {
    transform: scale(0.98);
    box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.member-left {
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 0;
}

.member-avatar {
    width: 88rpx;
    height: 88rpx;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 20rpx;
    flex-shrink: 0;
}

.member-avatar image {
    width: 100%;
    height: 100%;
}

.avatar-placeholder {
    font-size: 40rpx;
}

.member-info {
    display: flex;
    flex-direction: column;
    gap: 8rpx;
    min-width: 0;
    flex: 1;
}

.member-name-row {
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.member-name {
    font-size: 28rpx;
    font-weight: 500;
    color: #1a1a1a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 160rpx;
}

.level-badge {
    font-size: 18rpx;
    color: #fff;
    background: linear-gradient(135deg, #16a34a, #15803d);
    padding: 4rpx 12rpx;
    border-radius: 16rpx;
    flex-shrink: 0;
}

.member-time {
    font-size: 22rpx;
    color: #9ca3af;
}

.member-right {
    display: flex;
    align-items: center;
    gap: 16rpx;
}

.device-stats {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8rpx;
}

.device-total {
    display: flex;
    align-items: baseline;
    gap: 4rpx;
}

.device-num {
    font-size: 36rpx;
    font-weight: 700;
    color: #16a34a;
}

.device-label {
    font-size: 20rpx;
    color: #6b7280;
}

.device-status {
    display: flex;
    gap: 16rpx;
}

.status-item {
    display: flex;
    align-items: center;
    gap: 6rpx;
    font-size: 22rpx;
}

.status-item.online {
    color: #16a34a;
}

.status-item.offline {
    color: #f59e0b;
}

.mini-dot {
    width: 10rpx;
    height: 10rpx;
    border-radius: 50%;
}

.mini-dot.online {
    background: #16a34a;
}

.mini-dot.offline {
    background: #f59e0b;
}

.arrow-icon {
    font-size: 28rpx;
    color: #d1d5db;
}

/* 空状态 */
.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 80rpx 40rpx;
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(20px);
    border-radius: 24rpx;
    border: 1px solid rgba(255, 255, 255, 0.8);
}

.empty-icon {
    font-size: 100rpx;
    margin-bottom: 24rpx;
    opacity: 0.5;
}

.empty-title {
    font-size: 32rpx;
    font-weight: 500;
    color: #374151;
    margin-bottom: 12rpx;
}

.empty-desc {
    font-size: 26rpx;
    color: #9ca3af;
    margin-bottom: 32rpx;
}

.invite-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 240rpx;
    height: 80rpx;
    background: linear-gradient(135deg, #16a34a, #15803d);
    color: #fff;
    font-size: 28rpx;
    font-weight: 500;
    border-radius: 40rpx;
    box-shadow: 0 6rpx 20rpx rgba(22, 163, 74, 0.3);
}

/* 加载状态 */
.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60rpx;
    color: #6b7280;
    font-size: 26rpx;
}

.loading-spinner {
    width: 48rpx;
    height: 48rpx;
    border: 4rpx solid #e5e7eb;
    border-top-color: #16a34a;
    border-radius: 50%;
    margin-bottom: 20rpx;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to {
        transform: rotate(360deg);
    }
}