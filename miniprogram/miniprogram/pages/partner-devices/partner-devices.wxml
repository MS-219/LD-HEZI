<scroll-view class="scrollarea" scroll-y type="list">
    <view class="container">
        <!-- 自定义导航栏 -->
        <view class="custom-nav" style="padding-top: {{navBarTop}}px; height: {{navBarHeight}}px;">
            <view class="nav-back" bindtap="goBack">
                <text class="back-icon">‹</text>
            </view>
            <text class="nav-title">伙伴设备</text>
        </view>
        <!-- 总览统计卡片 -->
        <view class="summary-card">
            <view class="summary-header">
                <text class="summary-title">设备总览</text>
                <text class="summary-subtitle">我邀请的伙伴设备状态</text>
            </view>
            <view class="summary-stats">
                <view class="stat-item">
                    <text class="stat-num">{{totalMembers}}</text>
                    <text class="stat-label">邀请人数</text>
                </view>
                <view class="stat-divider"></view>
                <view class="stat-item">
                    <text class="stat-num">{{totalDevices}}</text>
                    <text class="stat-label">设备总数</text>
                </view>
                <view class="stat-divider"></view>
                <view class="stat-item clickable" bindtap="onStatTap" data-status="online">
                    <view class="status-row">
                        <view class="status-dot online"></view>
                        <text class="stat-num online">{{totalOnline}}</text>
                    </view>
                    <text class="stat-label">在线</text>
                </view>
                <view class="stat-divider"></view>
                <view class="stat-item clickable" bindtap="onStatTap" data-status="offline">
                    <view class="status-row">
                        <view class="status-dot offline"></view>
                        <text class="stat-num offline">{{totalOffline}}</text>
                    </view>
                    <text class="stat-label">离线</text>
                </view>
            </view>
        </view>
        <!-- 成员列表 -->
        <view class="members-card" wx:if="{{members.length > 0}}">
            <view class="card-title">
                <text>伙伴列表</text>
                <text class="member-count">共 {{totalMembers}} 人</text>
            </view>
            <view class="members-list">
                <view class="member-item" wx:for="{{members}}" wx:key="id" bindtap="onMemberTap" data-member="{{item}}">
                    <view class="member-left">
                        <view class="member-avatar">
                            <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" mode="aspectFill"></image>
                            <text wx:else class="avatar-placeholder">👤</text>
                        </view>
                        <view class="member-info">
                            <view class="member-name-row">
                                <text class="member-name">{{item.nickname}}</text>
                                <view class="level-badge" wx:if="{{item.level > 0}}">
                                    Lv.{{item.level}}
                                </view>
                            </view>
                            <text class="member-time">加入于 {{item.createTime}}</text>
                        </view>
                    </view>
                    <view class="member-right">
                        <view class="device-stats">
                            <view class="device-total">
                                <text class="device-num">{{item.deviceCount}}</text>
                                <text class="device-label">设备</text>
                            </view>
                            <view class="device-status">
                                <view class="status-item online">
                                    <view class="mini-dot online"></view>
                                    <text>{{item.onlineCount}}</text>
                                </view>
                                <view class="status-item offline">
                                    <view class="mini-dot offline"></view>
                                    <text>{{item.offlineCount}}</text>
                                </view>
                            </view>
                        </view>
                        <text class="arrow-icon">›</text>
                    </view>
                </view>
            </view>
        </view>
        <!-- 空状态 -->
        <view class="empty-state" wx:if="{{!loading && members.length === 0}}">
            <text class="empty-icon">👥</text>
            <text class="empty-title">暂无伙伴设备</text>
            <text class="empty-desc">邀请好友加入，一起赚收益</text>
            <navigator url="/pages/invite/invite" class="invite-btn">
                <text>去邀请</text>
            </navigator>
        </view>
        <!-- 加载中 -->
        <view class="loading-state" wx:if="{{loading}}">
            <view class="loading-spinner"></view>
            <text>加载中...</text>
        </view>
    </view>
</scroll-view>